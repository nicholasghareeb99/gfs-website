---
import FencePage from '../../components/FencePage.astro';

const benefits = [
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', title: 'Natural Rot Resistance', text: 'Cedar contains natural oils that resist decay, insects, and moisture 芒聙聰 no chemical treatment needed.' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>', title: 'Beautiful Natural Look', text: 'Rich warm tones that age gracefully to a distinguished silver patina, or stain it to preserve the original color.' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>', title: '20+ Year Lifespan', text: 'With minimal care, cedar fences easily last 20-30 years. Much longer than pressure-treated pine alternatives.' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>', title: 'Complete Privacy', text: '6-foot solid board construction with no gaps. Board-on-board and shadowbox options available for airflow.' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>', title: 'Michigan Sourced', text: 'We use premium Northern White Cedar sourced from Michigan mills 芒聙聰 supporting local and getting the best quality.' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>', title: '4x6 Gate Posts', text: 'Oversized gate posts prevent sagging and keep your gates swinging true for years to come.' },
];

const specs = [
  { label: 'Post Size', value: '4x4 Line / 4x6 Gate' },
  { label: 'Board Thickness', value: '1" Full Dimension' },
  { label: 'Standard Height', value: '6 Foot' },
  { label: 'Post Depth', value: '36" Minimum' },
  { label: 'Warranty', value: '3 Year Craftsmanship' },
  { label: 'Lifespan', value: '20-30 Years' },
];

const faqs = [
  { question: 'How long does a cedar fence last?', answer: 'With proper care, a cedar fence can last 20-30 years or more. Cedar naturally resists rot, decay, and insects. You can extend its life by applying a sealant or stain every 3-5 years, though many homeowners love the natural silver patina that develops over time.' },
  { question: 'Should I stain my cedar fence?', answer: 'It depends on your preference. Left natural, cedar will age to a beautiful silver-gray patina within 1-2 years. If you prefer to maintain the warm honey color, apply a UV-protectant stain within the first year. Either way, cedar looks great.' },
  { question: 'What is the difference between cedar and pressure-treated wood?', answer: 'Cedar is naturally rot-resistant without chemical treatment, has a more attractive appearance, is lighter weight, and lasts longer. Pressure-treated wood is cheaper upfront but contains chemical preservatives, is heavier, more prone to warping, and typically needs replacing sooner.' },
  { question: 'How much does a cedar fence cost in Toledo?', answer: 'Cedar fence pricing varies based on linear footage, height, style (solid, shadowbox, board-on-board), and terrain. Use our instant quote tool for a detailed estimate, or call us for a free on-site consultation.' },
  { question: 'Do you use Northern White Cedar or Western Red Cedar?', answer: 'We primarily use premium Northern White Cedar sourced from Michigan mills. It performs exceptionally well in our Ohio/Michigan climate and supports local industry. Western Red Cedar is available by request for specific applications.' },
];

const galleryImages = [
  { src: '/images/gallery/cedar-shadowbox.jpg', alt: 'Cedar shadowbox fence Toledo', label: 'Cedar Shadowbox' },
  { src: '/images/gallery/cedar-lattice-shadowbox.jpg', alt: 'Cedar fence with lattice top', label: 'Lattice Top Cedar' },
  { src: '/images/gallery/cedar-full-yard.jpg', alt: 'Cedar full yard fence Perrysburg', label: 'Solid Cedar Privacy' },
  { src: '/images/gallery/cedar-detail.jpg', alt: 'Board on board cedar fence', label: 'Board on Board' },
  { src: '/images/gallery/cedar-gate-closeup.jpg', alt: 'Custom cedar gate', label: 'Custom Gate' },
  { src: '/images/gallery/cedar-lattice-detail.jpg', alt: 'Cedar lattice detail', label: 'Stained Cedar' },
];

const relatedTypes = [
  { name: 'Vinyl Privacy', href: '/fences/vinyl/', image: '/images/gallery/vinyl-white.jpg' },
  { name: 'Wood Privacy', href: '/fences/wood/', image: '/images/gallery/pt-privacy.jpg' },
  { name: 'Ornamental Aluminum', href: '/fences/aluminum/', image: '/images/gallery/aluminum-black.jpg' },
];
---

<FencePage
  title="Cedar Fence Installation Toledo OH | Ghareeb Fencing"
  description="Premium cedar fence installation in Toledo, OH. Michigan-sourced Northern White Cedar, 4x6 gate posts, 3-year warranty. Free quotes."
  keywords={['cedar fence toledo', 'cedar privacy fence', 'cedar fence installation ohio', 'northern white cedar fence']}
  heroTitle="Premium Cedar"
  heroHighlight="Privacy Fencing"
  heroText="The gold standard for privacy fencing. Our Michigan-sourced Northern White Cedar is naturally rot-resistant, beautifully warm, and built to last decades. Every fence features oversized 4x6 gate posts and meticulous craftsmanship."
  heroImage="/images/gallery/cedar-shadowbox.jpg"
  benefits={benefits}
  specs={specs}
  faqs={faqs}
  galleryImages={galleryImages}
  relatedTypes={relatedTypes}
>
  <!-- Cedar-specific: Style options -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Style Options</div>
        <h2 class="section-title">Cedar Fence <span class="gold">Styles We Install</span></h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto;">
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Solid Board Privacy</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Pickets butted together for complete privacy. 6ft height standard. Our most popular cedar style.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Shadowbox</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Alternating pickets front and back. Looks great from both sides. Allows airflow while maintaining privacy.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Privacy with Lattice Top</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Privacy panels with decorative lattice accent. Adds elegance, light, and airflow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Good / Better / Best 脙垄脗聙脗聰 Brochure-style horizontal cards -->
    <section class="gbb-section">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Style Options</div>
      <h2 class="section-title">Cedar Fence <span class="gold">Options</span></h2>
    </div>
    <div class="gbb-grid">
      <div class="gbb-card">
        <div class="gbb-badge">GOOD</div>
        <div class="gbb-title-area">
          <div class="gbb-card-title">Pressure Treated Pine</div>
          <div class="gbb-card-subtitle">Budget-Friendly Option</div>
        </div>
        <img class="gbb-photo" src="/images/gallery/pt-privacy.jpg" alt="Pressure treated fence">
        <div class="gbb-specs">
          <div class="gbb-specs-title">SPECIFICATIONS</div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Privacy</span><span class="gbb-spec-value">90-100%</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Lifespan</span><span class="gbb-spec-value">10-15 years</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Material</span><span class="gbb-spec-value">Chemical treated</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Maintenance</span><span class="gbb-spec-value">High</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Cost</span><span class="gbb-spec-value">$</span></div>
        </div>
        <div class="gbb-pros"><div class="gbb-pros-title">PROS</div><ul>
          <li>Most affordable option</li>
          <li>Classic neighborhood look</li>
          <li>Quick installation</li>
          <li>Easy board replacement</li>
        </ul></div>
        <div class="gbb-cons"><div class="gbb-cons-title">CONS</div><ul>
          <li>Chemical wears off over time</li>
          <li>Cracks and splits with age</li>
          <li>Warps when drying</li>
          <li>Frequent maintenance required</li>
        </ul></div>
      </div>
      <div class="gbb-card">
        <div class="gbb-badge">BETTER</div>
        <div class="gbb-title-area">
          <div class="gbb-card-title">Western Red Cedar</div>
          <div class="gbb-card-subtitle">Natural Beauty</div>
        </div>
        <img class="gbb-photo" src="/images/gallery/cedar-shadowbox.jpg" alt="Western Red Cedar fence">
        <div class="gbb-specs">
          <div class="gbb-specs-title">SPECIFICATIONS</div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Privacy</span><span class="gbb-spec-value">100%</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Lifespan</span><span class="gbb-spec-value">20-25 years</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Material</span><span class="gbb-spec-value">Natural oils</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Maintenance</span><span class="gbb-spec-value">Moderate</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Cost</span><span class="gbb-spec-value">$$</span></div>
        </div>
        <div class="gbb-pros"><div class="gbb-pros-title">PROS</div><ul>
          <li>Natural oil resistance</li>
          <li>Beautiful wood grain</li>
          <li>Good dimensional stability</li>
          <li>No chemical treatment needed</li>
        </ul></div>
        <div class="gbb-cons"><div class="gbb-cons-title">CONS</div><ul>
          <li>Optional staining every 2-3 years</li>
          <li>Moderate price point</li>
          <li>Weathers to silver-gray if unsealed</li>
        </ul></div>
      </div>
      <div class="gbb-card best">
        <div class="gbb-badge">BEST</div>
        <div class="gbb-recommended">脙垄脗聵脗聟 RECOMMENDED</div>
        <div class="gbb-title-area">
          <div class="gbb-card-title">Northern White Cedar</div>
          <div class="gbb-card-subtitle">Michigan Sourced Premium</div>
        </div>
        <img class="gbb-photo" src="/images/gallery/cedar-lattice-shadowbox.jpg" alt="Northern White Cedar fence">
        <div class="gbb-specs">
          <div class="gbb-specs-title">SPECIFICATIONS</div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Privacy</span><span class="gbb-spec-value">100%</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Lifespan</span><span class="gbb-spec-value">30-40+ years</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Material</span><span class="gbb-spec-value">Michigan N. White</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Maintenance</span><span class="gbb-spec-value">Low</span></div>
          <div class="gbb-spec-row"><span class="gbb-spec-label">Cost</span><span class="gbb-spec-value">$$$$</span></div>
        </div>
        <div class="gbb-pros"><div class="gbb-pros-title">PROS</div><ul>
          <li>Exceptional rot resistance</li>
          <li>30-40+ year lifespan</li>
          <li>Superior dimensional stability</li>
          <li>Lightweight yet strong</li>
          <li>Sustainably sourced</li>
        </ul></div>
        <div class="gbb-cons"><div class="gbb-cons-title">CONS</div><ul>
          <li>Premium price point</li>
          <li>Limited local availability</li>
        </ul></div>
      </div>
    </div>
    <div class="gbb-summary">
      <div class="gbb-summary-title">WHICH OPTION IS RIGHT FOR YOU?</div>
      <div class="gbb-summary-grid">
        <div class="gbb-summary-item"><strong>Pressure Treated Pine</strong><span>Budget projects, side yards</span></div>
        <div class="gbb-summary-item"><strong>Western Red Cedar</strong><span>Beautiful natural look, great value</span></div>
        <div class="gbb-summary-item"><strong>Northern White Cedar</strong><span>Premium longevity, best investment</span></div>
      </div>
      <p class="gbb-availability">All styles available in multiple configurations: privacy, shadowbox, lattice top, and board-on-board</p>
    </div>
    <div class="gbb-contact-bar">
      <p>Not sure which cedar is right for you? We'll help you choose.</p>
      <a href="tel:4199028257">(419) 902-8257</a>
    </div>
  </div>
</section>

  <!-- Warranty -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Peace of Mind</div>
        <h2 class="section-title">Our Cedar Fence <span class="gold">Warranty</span></h2>
      </div>
      <div class="warranty-grid">
        <div class="warranty-card">
          <div class="warranty-badge">3 YEAR<span>Workmanship Warranty</span></div>
          <p class="warranty-text">Covers post setting and alignment, hardware and fasteners, picket installation, rails and framework, and gate operation</p>
        </div>
        <div class="warranty-card">
          <div class="warranty-badge">20-40+<span>YEARS Natural Cedar Lifespan</span></div>
          <ul class="warranty-list">
            <li>芒聹聯  Western Red Cedar: 20-25 years</li>
            <li>芒聹聯  Northern White Cedar: 30-40+ years</li>
            <li>芒聹聯  Natural rot/insect resistance</li>
            <li>芒聹聯  Can be sealed for longevity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</FencePage>

