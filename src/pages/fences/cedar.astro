---
import FencePage from '../../components/FencePage.astro';

const benefits = [
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', title: 'Natural Rot Resistance', text: 'Cedar contains natural oils that resist decay, insects, and moisture ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ no chemical treatment needed.' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>', title: 'Beautiful Natural Look', text: 'Rich warm tones that age gracefully to a distinguished silver patina, or stain it to preserve the original color.' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>', title: '20+ Year Lifespan', text: 'With minimal care, cedar fences easily last 20-30 years. Much longer than pressure-treated pine alternatives.' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>', title: 'Complete Privacy', text: '6-foot solid board construction with no gaps. Board-on-board and shadowbox options available for airflow.' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>', title: 'Michigan Sourced', text: 'We use premium Northern White Cedar sourced from Michigan mills ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ supporting local and getting the best quality.' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>', title: '4x6 Gate Posts', text: 'Oversized gate posts prevent sagging and keep your gates swinging true for years to come.' },
];

const specs = [
  { label: 'Post Size', value: '4x4 Line / 4x6 Gate' },
  { label: 'Board Thickness', value: '1" Full Dimension' },
  { label: 'Standard Height', value: '6 Foot' },
  { label: 'Post Depth', value: '36" Minimum' },
  { label: 'Warranty', value: '3 Year Craftsmanship' },
  { label: 'Lifespan', value: '20-30 Years' },
];

const faqs = [
  { question: 'How long does a cedar fence last?', answer: 'With proper care, a cedar fence can last 20-30 years or more. Cedar naturally resists rot, decay, and insects. You can extend its life by applying a sealant or stain every 3-5 years, though many homeowners love the natural silver patina that develops over time.' },
  { question: 'Should I stain my cedar fence?', answer: 'It depends on your preference. Left natural, cedar will age to a beautiful silver-gray patina within 1-2 years. If you prefer to maintain the warm honey color, apply a UV-protectant stain within the first year. Either way, cedar looks great.' },
  { question: 'What is the difference between cedar and pressure-treated wood?', answer: 'Cedar is naturally rot-resistant without chemical treatment, has a more attractive appearance, is lighter weight, and lasts longer. Pressure-treated wood is cheaper upfront but contains chemical preservatives, is heavier, more prone to warping, and typically needs replacing sooner.' },
  { question: 'How much does a cedar fence cost in Toledo?', answer: 'Cedar fence pricing varies based on linear footage, height, style (solid, shadowbox, board-on-board), and terrain. Use our instant quote tool for a detailed estimate, or call us for a free on-site consultation.' },
  { question: 'Do you use Northern White Cedar or Western Red Cedar?', answer: 'We primarily use premium Northern White Cedar sourced from Michigan mills. It performs exceptionally well in our Ohio/Michigan climate and supports local industry. Western Red Cedar is available by request for specific applications.' },
];

const galleryImages = [
  { src: '/images/gallery/cedar-shadowbox.jpg', alt: 'Cedar shadowbox fence Toledo', label: 'Cedar Shadowbox' },
  { src: '/images/gallery/cedar-lattice-shadowbox.jpg', alt: 'Cedar fence with lattice top', label: 'Lattice Top Cedar' },
  { src: '/images/gallery/cedar-full-yard.jpg', alt: 'Cedar full yard fence Perrysburg', label: 'Solid Cedar Privacy' },
  { src: '/images/gallery/cedar-detail.jpg', alt: 'Board on board cedar fence', label: 'Board on Board' },
  { src: '/images/gallery/cedar-gate-closeup.jpg', alt: 'Custom cedar gate', label: 'Custom Gate' },
  { src: '/images/gallery/cedar-lattice-detail.jpg', alt: 'Cedar lattice detail', label: 'Stained Cedar' },
];

const relatedTypes = [
  { name: 'Vinyl Privacy', href: '/fences/vinyl/', image: '/images/gallery/vinyl-white.jpg' },
  { name: 'Wood Privacy', href: '/fences/wood/', image: '/images/gallery/pt-privacy.jpg' },
  { name: 'Ornamental Aluminum', href: '/fences/aluminum/', image: '/images/gallery/aluminum-black.jpg' },
];
---

<FencePage
  title="Cedar Fence Installation Toledo OH | Ghareeb Fencing"
  description="Premium cedar fence installation in Toledo, OH. Michigan-sourced Northern White Cedar, 4x6 gate posts, 3-year warranty. Free quotes."
  keywords={['cedar fence toledo', 'cedar privacy fence', 'cedar fence installation ohio', 'northern white cedar fence']}
  heroTitle="Premium Cedar"
  heroHighlight="Privacy Fencing"
  heroText="The gold standard for privacy fencing. Our Michigan-sourced Northern White Cedar is naturally rot-resistant, beautifully warm, and built to last decades. Every fence features oversized 4x6 gate posts and meticulous craftsmanship."
  heroImage="/images/gallery/cedar-shadowbox.jpg"
  benefits={benefits}
  specs={specs}
  faqs={faqs}
  galleryImages={galleryImages}
  relatedTypes={relatedTypes}
>
  <!-- Cedar-specific: Style options -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Style Options</div>
        <h2 class="section-title">Cedar Fence <span class="gold">Styles We Install</span></h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto;">
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Solid Board Privacy</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Pickets butted together for complete privacy. 6ft height standard. Our most popular cedar style.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Shadowbox</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Alternating pickets front and back. Looks great from both sides. Allows airflow while maintaining privacy.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Privacy with Lattice Top</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Privacy panels with decorative lattice accent. Adds elegance, light, and airflow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Good / Better / Best — Brochure-style horizontal cards -->
    <section class="section gbb-section">
      <div class="container" style="text-align:center">
        <div class="section-label">Style Options</div>
        <h2 class="section-title">Cedar Fence Options: <span class="gold">Good / Better / Best</span></h2>
        <p>Three wood options — one clear winner for dimensional stability and beauty</p>
      </div>

      <div class="gbb-grid">
        <div class="gbb-card">
          <div class="gbb-badge gbb-good">GOOD</div>
          <h3 class="gbb-name">Pressure Treated Pine</h3>
          <ul class="gbb-features">
            <li>Chemical-dependent preservation</li>
            <li>10–15 year lifespan</li>
            <li>Prone to warping &amp; splitting</li>
            <li>High maintenance required</li>
          </ul>
          <a href="/quote/" class="gbb-btn">Get Quote</a>
        </div>

        <div class="gbb-card">
          <div class="gbb-badge gbb-better">BETTER</div>
          <h3 class="gbb-name">Western Red Cedar</h3>
          <ul class="gbb-features">
            <li>Natural oil resistance</li>
            <li>20–25 year lifespan</li>
            <li>Good dimensional stability</li>
            <li>Moderate maintenance</li>
          </ul>
          <a href="/quote/" class="gbb-btn">Get Quote</a>
        </div>

        <div class="gbb-card gbb-card-best">
          <div class="gbb-recommended">★ RECOMMENDED</div>
          <div class="gbb-badge gbb-best">BEST</div>
          <h3 class="gbb-name">Northern White Cedar</h3>
          <ul class="gbb-features">
            <li>Exceptional decay resistance</li>
            <li>30–40+ year lifespan</li>
            <li>Superior dimensional stability</li>
            <li>Low maintenance</li>
          </ul>
          <a href="/quote/" class="gbb-btn gbb-btn-best">Get Quote</a>
        </div>
      </div>

      <!-- Limitations vs Advantages -->
      <div class="gbb-compare-row">
        <div class="gbb-compare-card gbb-compare-bad">
          <h3>PT Pine Limitations</h3>
          <ul>
            <li><span class="x-mark">✗</span> Chemical wears off over time</li>
            <li><span class="x-mark">✗</span> Cracks and splits</li>
            <li><span class="x-mark">✗</span> Warps when drying</li>
            <li><span class="x-mark">✗</span> Frequent maintenance needed</li>
            <li><span class="x-mark">✗</span> Shorter lifespan</li>
          </ul>
        </div>
        <div class="gbb-compare-card gbb-compare-good">
          <h3>Cedar Advantages</h3>
          <ul>
            <li><span class="check-mark">✓</span> Natural decay resistance</li>
            <li><span class="check-mark">✓</span> Dimensionally stable</li>
            <li><span class="check-mark">✓</span> Beautiful natural grain</li>
            <li><span class="check-mark">✓</span> Lightweight &amp; strong</li>
            <li><span class="check-mark">✓</span> Sustainable &amp; renewable</li>
          </ul>
        </div>
      </div>

      <!-- Cedar Options Table -->
      <div class="gbb-options-table">
        <h3 class="gbb-table-title">Cedar Fence Options at a Glance</h3>
        <table>
          <thead>
            <tr>
              <th>Style</th>
              <th>Material</th>
              <th>Privacy</th>
              <th>Lifespan</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Cedar Privacy</td><td>WRC</td><td>100%</td><td>20–25 yrs</td></tr>
            <tr><td>Cedar Shadowbox</td><td>WRC</td><td>85%</td><td>20–25 yrs</td></tr>
            <tr><td>Lattice Top</td><td>WRC</td><td>75%</td><td>20–25 yrs</td></tr>
            <tr><td>PT Frame + Cedar</td><td>Hybrid</td><td>100%</td><td>18–22 yrs</td></tr>
            <tr class="gbb-table-highlight"><td>Premium White Cedar</td><td>N. White</td><td>100%</td><td>30–40+ yrs</td></tr>
          </tbody>
        </table>
      </div>
    </section>

  <!-- Warranty -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Peace of Mind</div>
        <h2 class="section-title">Our Cedar Fence <span class="gold">Warranty</span></h2>
      </div>
      <div class="warranty-grid">
        <div class="warranty-card">
          <div class="warranty-badge">3 YEAR<span>Workmanship Warranty</span></div>
          <p class="warranty-text">Covers post setting and alignment, hardware and fasteners, picket installation, rails and framework, and gate operation</p>
        </div>
        <div class="warranty-card">
          <div class="warranty-badge">20-40+<span>YEARS Natural Cedar Lifespan</span></div>
          <ul class="warranty-list">
            <li>ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ Western Red Cedar: 20-25 years</li>
            <li>ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ Northern White Cedar: 30-40+ years</li>
            <li>ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ Natural rot/insect resistance</li>
            <li>ÃÂÃÂ¢ÃÂÃÂÃÂÃÂ Can be sealed for longevity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</FencePage>

<style is:global>
/* Good / Better / Best — Premium Brochure Style */
  .gbb-section { padding: 80px 0; }
  .gbb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1000px; margin: 40px auto 0; }
  .gbb-card { background: #fff; border: 2px solid #e8e8e8; border-radius: 16px; padding: 40px 28px 32px; text-align: center; position: relative; transition: all 0.3s ease; }
  .gbb-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
  .gbb-card-best { border-color: #c9a84c; box-shadow: 0 4px 20px rgba(201,168,76,0.15); }
  .gbb-badge { display: inline-block; padding: 8px 28px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; margin-bottom: 20px; }
  .gbb-good { background: #c9a84c; color: #fff; }
  .gbb-better { background: #1b2d4f; color: #fff; }
  .gbb-best { background: #c9a84c; color: #fff; }
  .gbb-recommended { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #c9a84c; color: #fff; padding: 4px 18px; border-radius: 50px; font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; white-space: nowrap; }
  .gbb-name { font-size: 1.25rem; font-weight: 700; color: #1b2d4f; margin: 0 0 20px; font-family: 'Playfair Display', serif; }
  .gbb-features { list-style: none; padding: 0; margin: 0 0 24px; text-align: left; }
  .gbb-features li { padding: 8px 0; border-bottom: 1px solid #f0f0f0; font-size: 0.95rem; color: #444; }
  .gbb-features li:last-child { border-bottom: none; }
  .gbb-btn { display: inline-block; padding: 12px 28px; border: 2px solid #1b2d4f; color: #1b2d4f; border-radius: 50px; font-weight: 600; text-decoration: none; font-size: 0.9rem; transition: all 0.3s; }
  .gbb-btn:hover { background: #1b2d4f; color: #fff; }
  .gbb-btn-best { background: #c9a84c; border-color: #c9a84c; color: #fff; }
  .gbb-btn-best:hover { background: #b8943d; border-color: #b8943d; }

  /* Limitations vs Advantages */
  .gbb-compare-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1000px; margin: 48px auto 0; }
  .gbb-compare-card { background: #fff; border: 2px solid #e8e8e8; border-radius: 16px; padding: 32px; }
  .gbb-compare-card h3 { font-size: 1.1rem; font-weight: 700; margin: 0 0 16px; font-family: 'Playfair Display', serif; }
  .gbb-compare-bad h3 { color: #c0392b; }
  .gbb-compare-good h3 { color: #1b2d4f; }
  .gbb-compare-card ul { list-style: none; padding: 0; margin: 0; }
  .gbb-compare-card li { padding: 6px 0; font-size: 0.95rem; color: #444; }
  .x-mark { color: #c0392b; font-weight: 700; margin-right: 8px; }
  .check-mark { color: #27ae60; font-weight: 700; margin-right: 8px; }

  /* Options Table */
  .gbb-options-table { max-width: 1000px; margin: 48px auto 0; }
  .gbb-table-title { text-align: center; font-size: 1.1rem; color: #c9a84c; text-transform: uppercase; letter-spacing: 2px; font-weight: 600; margin-bottom: 16px; }
  .gbb-options-table table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .gbb-options-table thead { background: #1b2d4f; color: #fff; }
  .gbb-options-table th { padding: 14px 20px; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; text-align: left; }
  .gbb-options-table td { padding: 14px 20px; font-size: 0.95rem; color: #444; border-bottom: 1px solid #f0f0f0; }
  .gbb-options-table tr:last-child td { border-bottom: none; }
  .gbb-table-highlight { background: #faf6eb; }
  .gbb-table-highlight td { font-weight: 600; color: #1b2d4f; }

  @media(max-width:768px){
    .gbb-grid { grid-template-columns: 1fr; max-width: 400px; }
    .gbb-compare-row { grid-template-columns: 1fr; }
  }
</style>
