.gbb-section { padding: 80px 0; background: #f8f7f4; }
.gbb-grid {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr) !important;
  gap: 28px; max-width: 1080px; margin: 48px auto 0;
}
/* Card Base */
.gbb-card {
  background: #fff; border: 2px solid #e8e8e8; border-radius: 12px;
  padding: 0; text-align: center; position: relative;
  transition: all 0.35s ease; overflow: hidden;
  display: flex; flex-direction: column;
}
.gbb-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.1); }
.gbb-card.best { border-color: #c9a84c; box-shadow: 0 4px 24px rgba(201,168,76,0.18); }

/* Badge (top bar) */
.gbb-badge {
  display: block; padding: 14px 0; font-size: 0.8rem; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase; color: #fff;
}
.gbb-card:nth-child(1) .gbb-badge { background: #8a8a8a; }
.gbb-card:nth-child(2) .gbb-badge { background: #1b2d4f; }
.gbb-card:nth-child(3) .gbb-badge { background: linear-gradient(135deg, #c9a84c, #dbb960); }

/* Recommended tag */
.gbb-recommended {
  position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
  background: #c9a84c; color: #fff; padding: 4px 18px; border-radius: 0 0 12px 12px;
  font-size: 0.65rem; font-weight: 700; letter-spacing: 1.5px; white-space: nowrap; z-index: 2;
}

/* Title Area */
.gbb-title-area { padding: 28px 24px 16px; }
.gbb-card-title {
  font-size: 1.2rem; font-weight: 700; color: #1b2d4f;
  font-family: 'Playfair Display', serif; margin: 0 0 4px;
}
.gbb-card-subtitle { font-size: 0.85rem; color: #888; font-weight: 500; }

/* Specs */
.gbb-specs { padding: 0 24px 16px; flex: 1; }
.gbb-specs-title {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: #1b2d4f; margin-bottom: 12px;
  padding-bottom: 8px; border-bottom: 2px solid #f0f0f0;
}
.gbb-spec-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 7px 0; border-bottom: 1px solid #f5f5f5; font-size: 0.88rem;
}
.gbb-spec-row:last-child { border-bottom: none; }
.gbb-spec-label { color: #777; font-weight: 500; }
.gbb-spec-value { color: #1b2d4f; font-weight: 600; text-align: right; }

/* Highlights */
.gbb-pros { padding: 0 24px 16px; }
.gbb-pros-title {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: #1b2d4f; margin-bottom: 10px;
  padding-bottom: 8px; border-bottom: 2px solid #f0f0f0;
}
.gbb-pros ul { list-style: none; padding: 0; margin: 0; text-align: left; }
.gbb-pros li {
  padding: 6px 0 6px 22px; font-size: 0.88rem; color: #444;
  position: relative;
}
.gbb-pros li::before {
  content: '\2713'; position: absolute; left: 0; color: #27ae60; font-weight: 700;
}

/* CTA Button */
.gbb-cta {
  display: block; margin: auto 24px 24px; padding: 14px 0;
  border: 2px solid #1b2d4f; color: #1b2d4f; border-radius: 50px;
  font-weight: 700; text-decoration: none; font-size: 0.9rem;
  letter-spacing: 1px; transition: all 0.3s; text-align: center;
}
.gbb-cta:hover { background: #1b2d4f; color: #fff; }
.gbb-card.best .gbb-cta {
  background: #c9a84c; border-color: #c9a84c; color: #fff;
}
.gbb-card.best .gbb-cta:hover { background: #b8943d; border-color: #b8943d; }

/* Contact Bar */
.gbb-contact-bar {
  display: flex; align-items: center; justify-content: center; gap: 16px;
  background: #1b2d4f; color: #fff; padding: 20px 32px; border-radius: 12px;
  max-width: 1080px; margin: 32px auto 0; flex-wrap: wrap; text-align: center;
}
.gbb-contact-bar p { margin: 0; font-size: 0.95rem; }
.gbb-contact-bar a {
  color: #c9a84c; font-weight: 700; font-size: 1.1rem; text-decoration: none;
}
.gbb-contact-bar a:hover { text-decoration: underline; }

/* Responsive */
@media(max-width: 900px){
  .gbb-grid { grid-template-columns: 1fr !important; max-width: 420px; }
}
