<FencePage
  title="Cedar Fence Installation Toledo OH | Ghareeb Fencing"
  description="Premium cedar fence installation in Toledo, OH. Michigan-sourced Northern White Cedar, 4x6 gate posts, 3-year warranty. Free quotes."
  keywords={['cedar fence toledo', 'cedar privacy fence', 'cedar fence installation ohio', 'northern white cedar fence']}
  heroTitle="Premium Cedar"
  heroHighlight="Privacy Fencing"
  heroText="The gold standard for privacy fencing. Our Michigan-sourced Northern White Cedar is naturally rot-resistant, beautifully warm, and built to last decades. Every fence features oversized 4x6 gate posts and meticulous craftsmanship."
  heroImage="/images/gallery/cedar-shadowbox.jpg"
  benefits={benefits}
  specs={specs}
  faqs={faqs}
  galleryImages={galleryImages}
  relatedTypes={relatedTypes}
>
  <!-- Cedar-specific: Style options -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Style Options</div>
        <h2 class="section-title">Cedar Fence <span class="gold">Styles We Install</span></h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto;">
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Solid Board Privacy</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Pickets butted together for complete privacy. 6ft height standard. Our most popular cedar style.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Shadowbox</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Alternating pickets front and back. Looks great from both sides. Allows airflow while maintaining privacy.</p>
        </div>
        <div style="background: var(--bg-white); border-radius: var(--radius); padding: 24px; border: 1px solid var(--border); text-align: center;">
          <h4 style="margin-bottom: 8px;">Privacy with Lattice Top</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Privacy panels with decorative lattice accent. Adds elegance, light, and airflow.</p>
        </div>
      </div>
    </div>
  </section>

