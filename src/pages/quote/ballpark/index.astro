/* ======== MAP ======== */
let gmap=null;
window.searchMapAddress=function(addr){
    if(!addr)addr=$('map-address-input')?.value?.trim();if(!addr){$('map-status-text').textContent='Enter an address to search';return;}
    if(!window.google||!window.google.maps){$('map-status-text').textContent='\u26a0\ufe0f Maps not loaded. Click Satellite Map tab again in a moment.';return;}
    $('map-status-text').textContent='\U0001f50d Searching for your property...';$('map-instructions').style.display='flex';
    const mapEl=$('map');

    /* If Places Autocomplete already gave us coords, use them directly — no geocoding needed */
    if(window._placeCoords){
        const pc=window._placeCoords;window._placeCoords=null;
        showMap(pc.lat,pc.lng);
        return;
    }

    function showMap(lat,lng){
        const mapEl=$('map');
        mapEl.innerHTML='';gmap=null;
        $('map-instructions').style.display='none';

        /* ---- Map objects (stored with lat/lng for GPS accuracy) ---- */
        let mapObjs=[];/* {type,points:[{lat,lng}],segments:[{dist}],fenceType,...} */
        let mapCfp=[];/* Current fence points being drawn */
        let mapMode='draw';/* 'draw' or 'pan' */
        let mapDragGate=null;

        /* ---- Create Google Map ---- */
        gmap=new google.maps.Map(mapEl,{center:{lat,lng},zoom:20,mapTypeId:'satellite',tilt:0,
            disableDefaultUI:true,zoomControl:true,gestureHandling:'greedy',
            mapTypeControl:true,mapTypeControlOptions:{style:google.maps.MapTypeControlStyle.DROPDOWN_MENU,position:google.maps.ControlPosition.TOP_RIGHT},
            draggable:false,scrollwheel:false,disableDoubleClickZoom:true});
        new google.maps.Marker({position:{lat,lng},map:gmap,title:'Your Property',
            icon:{path:google.maps.SymbolPath.CIRCLE,scale:8,fillColor:'#d4af37',fillOpacity:1,strokeColor:'#fff',strokeWeight:2}});

        /* ---- Canvas overlay ---- */
        const mc=$('map-canvas');
        const mcRect=mapEl.getBoundingClientRect();
        const dpr=window.devicePixelRatio||1;
        mc.width=mcRect.width*dpr;mc.height=mcRect.height*dpr;
        mc.style.width=mcRect.width+'px';mc.style.height=mcRect.height+'px';
        const mctx=mc.getContext('2d');mctx.scale(dpr,dpr);
        const mcW=mcRect.width,mcH=mcRect.height;

        /* ---- Projection via OverlayView ---- */
        let ovProj=null;
        const ov=new google.maps.OverlayView();
        ov.onAdd=function(){};ov.draw=function(){ovProj=this.getProjection();redrawMapCanvas();};ov.onRemove=function(){};
        ov.setMap(gmap);

        function ll2px(lt,ln){
            if(!ovProj)return null;
            try{return ovProj.fromLatLngToContainerPixel(new google.maps.LatLng(lt,ln));}catch(e){return null;}
        }
        function px2ll(x,y){
            if(!ovProj)return null;
            try{const ll=ovProj.fromContainerPixelToLatLng(new google.maps.Point(x,y));return{lat:ll.lat(),lng:ll.lng()};}catch(e){return null;}
        }
        function llDist(a,b){
            return Math.round(google.maps.geometry.spherical.computeDistanceBetween(
                new google.maps.LatLng(a.lat,a.lng),new google.maps.LatLng(b.lat,b.lng))*3.28084);
        }

        /* ---- Pan/Draw mode toggle ---- */
        function setMapMode(mode){
            mapMode=mode;
            mc.style.pointerEvents=(mode==='draw')?'auto':'none';
            mc.style.cursor=(mode==='draw')?'crosshair':'default';
            gmap.setOptions({draggable:mode==='pan',scrollwheel:mode==='pan',disableDoubleClickZoom:mode==='draw'});
            document.querySelectorAll('.map-mode-btn').forEach(b=>b.classList.remove('active'));
            $(mode==='draw'?'map-mode-draw':'map-mode-pan').classList.add('active');
        }
        $('map-mode-draw')?.addEventListener('click',()=>setMapMode('draw'));
        $('map-mode-pan')?.addEventListener('click',()=>setMapMode('pan'));
        setMapMode('draw');

        /* Allow two-finger zoom even in draw mode */
        mc.addEventListener('wheel',e=>{
            e.preventDefault();
            const z=gmap.getZoom();
            gmap.setZoom(z+(e.deltaY<0?1:-1));
        },{passive:false});

        /* ---- Redraw on map move ---- */
        google.maps.event.addListener(gmap,'idle',redrawMapCanvas);
        google.maps.event.addListener(gmap,'zoom_changed',()=>setTimeout(redrawMapCanvas,50));

        /* ---- Scale bar ---- */
        function updateScaleBar(){
            const center=gmap.getCenter();
            const zoom=gmap.getZoom();
            const mpp=156543.03392*Math.cos(center.lat()*Math.PI/180)/Math.pow(2,zoom);
            const fpp=mpp*3.28084;
            /* Find a nice round footage for ~100px */
            const rawFt=fpp*100;
            const nice=[10,20,25,50,100,150,200,250,500];
            let scaleFt=nice.find(n=>n>=rawFt*0.5)||nice[nice.length-1];
            const scalePx=Math.round(scaleFt/fpp);
            const sb=$('map-scale-bar');
            if(sb){sb.innerHTML='<div class="scale-line" style="width:'+scalePx+'px"></div><span>'+scaleFt+' ft</span>';}
        }
        google.maps.event.addListener(gmap,'idle',updateScaleBar);
        google.maps.event.addListener(gmap,'zoom_changed',updateScaleBar);

        /* ---- TOOL BADGE SYNC ---- */
        const toolNames={fence:'Fence ✏',propline:'Prop Line 📏',existing:'Old Fence 🔴','gate-walk':'Walk Gate 🚪','gate-drive':'Dbl Gate 🚗',tree:'Tree 🌳',house:'House 🏠',pool:'Pool 🏊',text:'Text 💬',erase:'Erase 🗑'};
        const badgeColors={fence:'#d4af37',propline:'#94a3b8',existing:'#ef4444','gate-walk':'#10b981','gate-drive':'#3b82f6',tree:'#22c55e',erase:'#ef4444'};
        window._syncMapTool=function(){
            const badge=$('map-active-tool');
            if(badge){badge.textContent=toolNames[tool]||tool;badge.style.background=badgeColors[tool]||'#1e3a5f';}
            redrawMapCanvas();
        };
        window._syncMapTool();

        /* ---- Get canvas-local coords from mouse/touch ---- */
        function mcPos(e){const r=mc.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}

        /* ---- DRAWING: Click to place points ---- */
        mc.addEventListener('click',function(e){
            if(mapMode!=='draw')return;
            const p=mcPos(e);const ll=px2ll(p.x,p.y);if(!ll)return;

            if(tool==='fence'||tool==='propline'||tool==='existing'){
                mapCfp.push(ll);redrawMapCanvas();return;
            }
            if(tool==='gate-walk'||tool==='gate-drive'){
                /* Snap to nearest map fence line */
                let snapLL=ll,snapDir='right';
                let bestDist=Infinity;
                mapObjs.forEach(o=>{
                    if(o.type!=='fence')return;
                    for(let i=0;i<o.points.length-1;i++){
                        const a=o.points[i],b=o.points[i+1];
                        const pa=ll2px(a.lat,a.lng),pb=ll2px(b.lat,b.lng);if(!pa||!pb)continue;
                        const dx=pb.x-pa.x,dy=pb.y-pa.y,len2=dx*dx+dy*dy;if(len2===0)continue;
                        let t=((p.x-pa.x)*dx+(p.y-pa.y)*dy)/len2;t=Math.max(0,Math.min(1,t));
                        const px2=pa.x+t*dx,py2=pa.y+t*dy;
                        const d=Math.sqrt((p.x-px2)**2+(p.y-py2)**2);
                        if(d<bestDist&&d<40){bestDist=d;
                            const snapPx=px2ll(px2,py2);if(snapPx)snapLL=snapPx;
                            const ang=Math.atan2(dy,dx);
                            const isV=Math.abs(Math.sin(ang))>Math.abs(Math.cos(ang));
                            snapDir=isV?(p.x<px2?'left':'right'):(p.y<py2?'up':'down');
                        }
                    }
                });
                pendingGate={x:0,y:0,type:tool,fromMap:true,mapLL:snapLL,suggestedDir:snapDir};
                openGM(0,0,tool,snapDir);
                return;
            }
            if(tool==='tree'){su();mapObjs.push({type:'tree',ll:ll});objs.push({type:'tree',x:0,y:0,fromMap:true});redrawMapCanvas();updateQ();asd();return;}
            if(tool==='erase'){
                /* Find nearest map object */
                let bestI=-1,bestD=Infinity;
                mapObjs.forEach((o,idx)=>{
                    if(o.type==='tree'){const pp=ll2px(o.ll.lat,o.ll.lng);if(pp){const d=Math.sqrt((p.x-pp.x)**2+(p.y-pp.y)**2);if(d<bestD){bestD=d;bestI=idx;}}}
                    if(o.type==='gate-walk'||o.type==='gate-drive'){const pp=ll2px(o.ll.lat,o.ll.lng);if(pp){const d=Math.sqrt((p.x-pp.x)**2+(p.y-pp.y)**2);if(d<bestD){bestD=d;bestI=idx;}}}
                    if(o.type==='fence'||o.type==='propline'||o.type==='existing'){
                        o.points.forEach(pt=>{const pp=ll2px(pt.lat,pt.lng);if(pp){const d=Math.sqrt((p.x-pp.x)**2+(p.y-pp.y)**2);if(d<bestD){bestD=d;bestI=idx;}}});
                    }
                });
                if(bestI>=0&&bestD<30){
                    const rem=mapObjs[bestI];mapObjs.splice(bestI,1);
                    /* Remove matching fromMap obj */
                    for(let i=objs.length-1;i>=0;i--){if(objs[i].fromMap&&objs[i].type===rem.type){objs.splice(i,1);break;}}
                    redrawMapCanvas();updateQ();asd();updateMBar();
                }
                return;
            }
        });

        /* ---- DRAWING: Mousemove preview ---- */
        let mapMouse=null;
        mc.addEventListener('mousemove',function(e){
            if(mapMode!=='draw')return;
            mapMouse=mcPos(e);redrawMapCanvas();
        });
        mc.addEventListener('mouseleave',function(){mapMouse=null;redrawMapCanvas();});

        /* ---- DRAWING: Double-click to finish line ---- */
        mc.addEventListener('dblclick',function(e){
            e.preventDefault();
            if(mapCfp.length>=2)finMapLine();
        });

        /* ---- TOUCH: Single tap=draw, two-finger=pan ---- */
        let mapTouches=0,mapLastTap=0;
        mc.addEventListener('touchstart',function(e){
            mapTouches=e.touches.length;
            if(mapTouches>=2){/* Two-finger: pass to map for pan/zoom */
                mc.style.pointerEvents='none';
                setTimeout(()=>{if(mapMode==='draw')mc.style.pointerEvents='auto';},500);
            }
        },{passive:true});
        mc.addEventListener('touchend',function(e){
            if(mapTouches>=2){mapTouches=0;return;}/* was a two-finger gesture */
            if(e.changedTouches.length===0)return;
            const t=e.changedTouches[0];const r=mc.getBoundingClientRect();
            const x=t.clientX-r.left,y=t.clientY-r.top;
            const now=Date.now();
            /* Double-tap detection */
            if(now-mapLastTap<300&&mapCfp.length>=2){finMapLine();mapLastTap=0;return;}
            mapLastTap=now;
            /* Simulate click */
            const ll=px2ll(x,y);if(!ll)return;
            if(tool==='fence'||tool==='propline'||tool==='existing'){mapCfp.push(ll);redrawMapCanvas();}
            else{/* Trigger click handler for gates, trees, erase */
                mc.dispatchEvent(new MouseEvent('click',{clientX:t.clientX,clientY:t.clientY}));
            }
        },{passive:true});

        /* ---- Finish current line ---- */
        function finMapLine(){
            if(mapCfp.length<2)return;
            const segs=[];
            for(let i=0;i<mapCfp.length-1;i++)segs.push({dist:llDist(mapCfp[i],mapCfp[i+1])});
            su();
            if(tool==='fence'||tool==='propline'||tool==='existing'){
                const mObj={type:tool==='fence'?'fence':tool,points:mapCfp.slice(),segments:segs};
                if(tool==='fence')mObj.fenceType={name:selFence?.name||'Wood Privacy',ppf:selFence?.ppf||28,sg:selFence?.sg||350,dg:selFence?.dg||650,color:selFence?.color||'#d4af37'};
                mapObjs.push(mObj);
                /* Create real obj for quote */
                const qObj={type:mObj.type,points:mObj.points.map(p=>({x:0,y:0,lat:p.lat,lng:p.lng})),segments:segs,fromMap:true};
                if(tool==='fence')qObj.fenceType=mObj.fenceType;
                objs.push(qObj);
            }
            mapCfp=[];
            redrawMapCanvas();updateQ();asd();updateMBar();
        }
        $('map-finish-line')?.addEventListener('click',finMapLine);

        /* ---- Gate confirmed from modal ---- */
        window._onMapGateConfirmed=function(dir,width){
            if(!pendingGate||!pendingGate.fromMap||!pendingGate.mapLL)return;
            su();
            mapObjs.push({type:pendingGate.type,ll:pendingGate.mapLL,dir:dir,width:width});
            objs.push({type:pendingGate.type,x:0,y:0,dir:dir,width:width,fromMap:true});
            pendingGate=null;
            redrawMapCanvas();updateQ();asd();updateMBar();
        };

        /* ---- Undo ---- */
        $('map-undo-line')?.addEventListener('click',function(){
            if(mapCfp.length>0){mapCfp.pop();redrawMapCanvas();return;}
            if(mapObjs.length>0){
                const rem=mapObjs.pop();
                for(let i=objs.length-1;i>=0;i--){if(objs[i].fromMap&&objs[i].type===rem.type){objs.splice(i,1);break;}}
                redrawMapCanvas();updateQ();asd();updateMBar();
            }
        });

        /* ---- Clear all ---- */
        $('map-clear-lines')?.addEventListener('click',function(){
            mapObjs=[];mapCfp=[];
            objs=objs.filter(o=>!o.fromMap);
            redrawMapCanvas();updateQ();asd();updateMBar();
        });

        /* ---- Measurement bar ---- */
        function updateMBar(){
            let fFt=0,eFt=0,pFt=0,gC=0,tC=0;
            mapObjs.forEach(o=>{
                if(o.type==='fence')fFt+=o.segments.reduce((s,g)=>s+g.dist,0);
                if(o.type==='existing')eFt+=o.segments.reduce((s,g)=>s+g.dist,0);
                if(o.type==='propline')pFt+=o.segments.reduce((s,g)=>s+g.dist,0);
                if(o.type==='gate-walk'||o.type==='gate-drive')gC++;
                if(o.type==='tree')tC++;
            });
            let txt='';
            if(fFt)txt+='Fence: '+fFt+'ft';
            if(eFt)txt+=(txt?' · ':'')+' Removal: '+eFt+'ft';
            if(pFt)txt+=(txt?' · ':'')+'Prop: '+pFt+'ft';
            if(gC)txt+=(txt?' · ':'')+'Gates: '+gC;
            if(tC)txt+=(txt?' · ':'')+'Trees: '+tC;
            if(!txt)txt='Draw fence lines on the map with accurate measurements';
            $('map-total-ft').textContent=txt;
        }

        /* ============ RENDER MAP CANVAS ============ */
        function redrawMapCanvas(){
            if(!mctx||!ovProj)return;
            mctx.clearRect(0,0,mcW,mcH);

            /* Draw completed objects */
            mapObjs.forEach(o=>{
                if(o.type==='fence')drawMFence(o);
                if(o.type==='propline')drawMPropLine(o);
                if(o.type==='existing')drawMExisting(o);
                if(o.type==='gate-walk'||o.type==='gate-drive')drawMGate(o);
                if(o.type==='tree')drawMTree(o);
            });

            /* Draw in-progress line */
            if(mapCfp.length>0){
                const pts=mapCfp.map(p=>ll2px(p.lat,p.lng)).filter(p=>p);
                const lnColor=tool==='propline'?'#94a3b8':tool==='existing'?'#ef4444':selFence?.color||'#FFD700';
                if(pts.length>0){
                    mctx.beginPath();mctx.moveTo(pts[0].x,pts[0].y);
                    for(let i=1;i<pts.length;i++)mctx.lineTo(pts[i].x,pts[i].y);
                    /* Preview to mouse */
                    if(mapMouse&&mapMode==='draw'){mctx.lineTo(mapMouse.x,mapMouse.y);}
                    mctx.strokeStyle=lnColor;mctx.lineWidth=4;mctx.setLineDash([8,6]);mctx.stroke();mctx.setLineDash([]);
                    /* Vertex dots */
                    pts.forEach((p,i)=>{mctx.beginPath();mctx.arc(p.x,p.y,5,0,Math.PI*2);mctx.fillStyle=i===0?'#10b981':lnColor;mctx.fill();mctx.strokeStyle='#fff';mctx.lineWidth=2;mctx.stroke();});
                    /* Segment labels */
                    for(let i=0;i<mapCfp.length-1;i++){
                        const ft=llDist(mapCfp[i],mapCfp[i+1]);
                        drawMLabel((pts[i].x+pts[i+1].x)/2,(pts[i].y+pts[i+1].y)/2,ft+'ft',lnColor);
                    }
                    /* Preview segment to mouse */
                    if(mapMouse&&mapMode==='draw'&&pts.length>0){
                        const lastPt=mapCfp[mapCfp.length-1];
                        const mousLL=px2ll(mapMouse.x,mapMouse.y);
                        if(mousLL){const pft=llDist(lastPt,mousLL);
                            if(pft>0)drawMLabel((pts[pts.length-1].x+mapMouse.x)/2,(pts[pts.length-1].y+mapMouse.y)/2,pft+'ft','rgba(255,255,255,0.8)');}
                    }
                    /* Running total */
                    let runFt=0;for(let i=0;i<mapCfp.length-1;i++)runFt+=llDist(mapCfp[i],mapCfp[i+1]);
                    if(runFt>0&&pts.length>1){
                        const lp=pts[pts.length-1];
                        drawMLabel(lp.x,lp.y-20,'Total: '+runFt+'ft','#fff',true);
                    }
                }
            }

            /* Erase mode highlight */
            if(tool==='erase'&&mapMouse&&mapMode==='draw'){
                mctx.beginPath();mctx.arc(mapMouse.x,mapMouse.y,20,0,Math.PI*2);
                mctx.strokeStyle='rgba(239,68,68,0.6)';mctx.lineWidth=2;mctx.setLineDash([4,4]);mctx.stroke();mctx.setLineDash([]);
            }
        }

        function drawMFence(o){
            const pts=o.points.map(p=>ll2px(p.lat,p.lng)).filter(p=>p);
            if(pts.length<2)return;
            const clr=o.fenceType?.color||'#FFD700';
            /* Thick line */
            mctx.beginPath();mctx.moveTo(pts[0].x,pts[0].y);
            for(let i=1;i<pts.length;i++)mctx.lineTo(pts[i].x,pts[i].y);
            mctx.strokeStyle=clr;mctx.lineWidth=5;mctx.lineCap='round';mctx.lineJoin='round';mctx.stroke();
            /* White dash overlay */
            mctx.strokeStyle='rgba(255,255,255,0.4)';mctx.lineWidth=2;mctx.setLineDash([8,8]);mctx.stroke();mctx.setLineDash([]);
            /* Vertices */
            pts.forEach(p=>{mctx.beginPath();mctx.arc(p.x,p.y,5,0,Math.PI*2);mctx.fillStyle=clr;mctx.fill();mctx.strokeStyle='#fff';mctx.lineWidth=2;mctx.stroke();});
            /* Segment labels */
            for(let i=0;i<o.segments.length;i++){
                if(i>=pts.length-1)break;
                drawMLabel((pts[i].x+pts[i+1].x)/2,(pts[i].y+pts[i+1].y)/2,o.segments[i].dist+'ft',clr);
            }
            /* Total */
            const tf=o.segments.reduce((s,g)=>s+g.dist,0);
            if(o.segments.length>1){
                const lp=pts[pts.length-1];
                mctx.font='bold 11px sans-serif';mctx.fillStyle='#fff';mctx.textAlign='center';
                mctx.fillText('Σ '+tf+'ft',lp.x,lp.y+18);mctx.textAlign='left';
            }
            /* Name label */
            if(pts.length>=2){
                const mx=(pts[0].x+pts[1].x)/2,my=(pts[0].y+pts[1].y)/2;
                mctx.font='8px sans-serif';mctx.fillStyle='rgba(255,255,255,0.7)';mctx.fillText(o.fenceType?.name||'Fence',mx+5,my+18);
            }
        }

        function drawMPropLine(o){
            const pts=o.points.map(p=>ll2px(p.lat,p.lng)).filter(p=>p);if(pts.length<2)return;
            mctx.beginPath();mctx.moveTo(pts[0].x,pts[0].y);for(let i=1;i<pts.length;i++)mctx.lineTo(pts[i].x,pts[i].y);
            mctx.strokeStyle='#94a3b8';mctx.lineWidth=3;mctx.setLineDash([10,6]);mctx.stroke();mctx.setLineDash([]);
            pts.forEach(p=>{mctx.beginPath();mctx.arc(p.x,p.y,4,0,Math.PI*2);mctx.fillStyle='#94a3b8';mctx.fill();});
            for(let i=0;i<o.segments.length&&i<pts.length-1;i++){
                drawMLabel((pts[i].x+pts[i+1].x)/2,(pts[i].y+pts[i+1].y)/2,o.segments[i].dist+'ft (prop)','#94a3b8');
            }
        }

        function drawMExisting(o){
            const pts=o.points.map(p=>ll2px(p.lat,p.lng)).filter(p=>p);if(pts.length<2)return;
            mctx.beginPath();mctx.moveTo(pts[0].x,pts[0].y);for(let i=1;i<pts.length;i++)mctx.lineTo(pts[i].x,pts[i].y);
            mctx.strokeStyle='#ef4444';mctx.lineWidth=3;mctx.setLineDash([6,4]);mctx.stroke();mctx.setLineDash([]);
            /* X marks */
            for(let i=0;i<pts.length-1;i++){const mx=(pts[i].x+pts[i+1].x)/2,my=(pts[i].y+pts[i+1].y)/2;
                mctx.strokeStyle='#ef4444';mctx.lineWidth=2;mctx.beginPath();mctx.moveTo(mx-5,my-5);mctx.lineTo(mx+5,my+5);mctx.stroke();mctx.beginPath();mctx.moveTo(mx+5,my-5);mctx.lineTo(mx-5,my+5);mctx.stroke();}
            for(let i=0;i<o.segments.length&&i<pts.length-1;i++){
                drawMLabel((pts[i].x+pts[i+1].x)/2,(pts[i].y+pts[i+1].y)/2,o.segments[i].dist+'ft (remove)','#ef4444');
            }
        }

        function drawMGate(o){
            const p=ll2px(o.ll.lat,o.ll.lng);if(!p)return;
            const clr=o.type==='gate-walk'?'#10b981':'#3b82f6';
            const w=o.width||(o.type==='gate-drive'?12:4);
            const r=Math.max(12,w*2);
            /* Gate icon */
            mctx.beginPath();mctx.arc(p.x,p.y,r,0,Math.PI*2);
            mctx.fillStyle=clr+'44';mctx.fill();mctx.strokeStyle=clr;mctx.lineWidth=2.5;mctx.stroke();
            /* Arrow for direction */
            const dirs={up:[0,-1],down:[0,1],left:[-1,0],right:[1,0]};
            const d=dirs[o.dir||'right']||[1,0];
            mctx.beginPath();mctx.moveTo(p.x,p.y);mctx.lineTo(p.x+d[0]*r*0.8,p.y+d[1]*r*0.8);
            mctx.strokeStyle=clr;mctx.lineWidth=2;mctx.stroke();
            /* Label */
            mctx.font='bold 10px sans-serif';mctx.fillStyle='#fff';mctx.textAlign='center';
            mctx.strokeStyle='rgba(0,0,0,0.6)';mctx.lineWidth=3;
            const lbl=(o.type==='gate-walk'?'Gate':'Dbl')+' '+w+'ft';
            mctx.strokeText(lbl,p.x,p.y+r+14);mctx.fillText(lbl,p.x,p.y+r+14);
            mctx.textAlign='left';
        }

        function drawMTree(o){
            const p=ll2px(o.ll.lat,o.ll.lng);if(!p)return;
            mctx.beginPath();mctx.arc(p.x,p.y,10,0,Math.PI*2);
            mctx.fillStyle='rgba(34,197,94,0.5)';mctx.fill();mctx.strokeStyle='#22c55e';mctx.lineWidth=2;mctx.stroke();
            mctx.font='14px sans-serif';mctx.textAlign='center';mctx.fillText('🌳',p.x,p.y+5);mctx.textAlign='left';
        }

        function drawMLabel(x,y,text,color,big){
            const fs=big?'bold 12px sans-serif':'bold 11px sans-serif';
            mctx.font=fs;const tw=mctx.measureText(text).width;
            const px=4,py=2;
            mctx.fillStyle='rgba(0,0,0,0.7)';
            mctx.beginPath();
            const rx=x-tw/2-px,ry=y-7-py,rw=tw+px*2,rh=14+py*2,cr=4;
            mctx.moveTo(rx+cr,ry);mctx.lineTo(rx+rw-cr,ry);mctx.quadraticCurveTo(rx+rw,ry,rx+rw,ry+cr);
            mctx.lineTo(rx+rw,ry+rh-cr);mctx.quadraticCurveTo(rx+rw,ry+rh,rx+rw-cr,ry+rh);
            mctx.lineTo(rx+cr,ry+rh);mctx.quadraticCurveTo(rx,ry+rh,rx,ry+rh-cr);
            mctx.lineTo(rx,ry+cr);mctx.quadraticCurveTo(rx,ry,rx+cr,ry);
            mctx.fill();
            mctx.strokeStyle=color;mctx.lineWidth=1.5;mctx.stroke();
            mctx.fillStyle=color;mctx.textAlign='center';mctx.fillText(text,x,y+4);
            mctx.textAlign='left';
        }

        updateScaleBar();
        $('map-status-text').textContent='';
    }

    /* Strategy: Try Geocoder first (4s timeout), then fallback to Places findPlaceFromQuery */
    let resolved=false;
    const geocodeTimeout=setTimeout(()=>{
        if(resolved)return;
        console.log('[Map] Geocoder timed out, trying Places API fallback...');
        $('map-status-text').textContent='\U0001f50d Trying alternate search...';
        tryPlacesFallback(addr);
    },4000);

    try{
        new google.maps.Geocoder().geocode({address:addr},(r,s)=>{
            if(resolved)return;resolved=true;clearTimeout(geocodeTimeout);
            if(s==='OK'&&r[0]){
                showMap(r[0].geometry.location.lat(),r[0].geometry.location.lng());
            }else{
                console.log('[Map] Geocoder status:',s,'— trying Places fallback');
                tryPlacesFallback(addr);
            }
        });
    }catch(e){
        if(!resolved){resolved=true;clearTimeout(geocodeTimeout);tryPlacesFallback(addr);}
    }

    function tryPlacesFallback(query){
        /* Use Places service — doesn't need Geocoding API enabled */
        try{
            if(!google.maps.places){$('map-status-text').textContent='\u26a0\ufe0f Places API not available. Enable Geocoding API in Google Cloud Console.';return;}
            /* Create a temporary invisible map just for the PlacesService */
            const tempDiv=document.createElement('div');
            const svc=new google.maps.places.PlacesService(tempDiv);
            svc.findPlaceFromQuery({query:query,fields:['geometry','name']},(results,status)=>{
                if(status==='OK'&&results&&results[0]&&results[0].geometry){
                    const loc=results[0].geometry.location;
                    showMap(loc.lat(),loc.lng());
                }else{
                    /* Last resort: try TextSearch */
                    svc.textSearch({query:query},(r2,s2)=>{
                        if(s2==='OK'&&r2&&r2[0]&&r2[0].geometry){
                            showMap(r2[0].geometry.location.lat(),r2[0].geometry.location.lng());
                        }else{
                            $('map-status-text').textContent='\u26a0\ufe0f Could not find address. Enable the Geocoding API in Google Cloud Console, or try a different address.';
                        }
                    });
                }
            });
        }catch(e2){
            console.error('[Map] Places fallback error:',e2);
            $('map-status-text').textContent='\u26a0\ufe0f Map search failed. Enable the Geocoding API in Google Cloud Console > APIs & Services > Library.';
        }
    }
};
if($('map-search-btn'))$('map-search-btn').addEventListener('click',()=>window.searchMapAddress());
if($('map-address-input'))$('map-address-input').addEventListener('keypress',e=>{if(e.key==='Enter'){e.preventDefault();window.searchMapAddress();}});

loadPricing();
})();
</script>

