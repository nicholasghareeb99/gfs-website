/* ======== DRAWING STATE ======== */
let canvas,ctx,GCS=20,GS=5;
let tool='fence',objs=[],cfp=[],dragS=null,undo=[];
let shiftHeld=false;
let gridMode='draw'; /* 'draw' or 'pan' */
let vpX=0,vpY=0; /* viewport pan offset */
let isPanning=false,panStart=null;
let pinchDist=0,pinchMid=null;
document.addEventListener('keydown',e=>{
    shiftHeld=e.shiftKey;
    if(e.key==='Escape'){if(cfp.length>0){cfp=[];redraw();}tool='fence';document.querySelectorAll('.draw-tool').forEach(b=>b.classList.remove('active'));document.querySelector('.draw-tool[data-tool=fence]')?.classList.add('active');}
    if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();$('grid-undo')?.click();}
});
document.addEventListener('keyup',e=>{shiftHeld=e.shiftKey;});

function initCanvas(){
    canvas=$('grid-canvas');if(!canvas)return;
    if(canvas._init)return;
    const wrapper=canvas.parentElement;
    const w=Math.min(wrapper.clientWidth,800);
    const h=Math.round(w*0.6);
    const dpr=window.devicePixelRatio||1;
    canvas.width=w*dpr;canvas.height=h*dpr;
    canvas.style.width=w+'px';canvas.style.height=h+'px';
    ctx=canvas.getContext('2d');ctx.scale(dpr,dpr);
    GCS=Math.max(14,Math.floor(w/40));
    canvas._init=true;canvas._w=w;canvas._h=h;
    canvas.addEventListener('click',onClick);canvas.addEventListener('mousemove',onMove);
    canvas.addEventListener('mousedown',onDown);canvas.addEventListener('mouseup',onUp);
    canvas.addEventListener('dblclick',onDbl);
    canvas.addEventListener('contextmenu',e=>{e.preventDefault();finLine();});
    canvas.addEventListener('touchstart',onTS,{passive:false});canvas.addEventListener('touchmove',onTM,{passive:false});canvas.addEventListener('touchend',onTE,{passive:false});
    canvas.addEventListener('wheel',(e)=>{e.preventDefault();if(e.deltaY<0&&GCS<40){GCS+=2;GS=Math.round(GCS/4)||1;}else if(e.deltaY>0&&GCS>8){GCS-=2;GS=Math.round(GCS/4)||1;}redraw();},{passive:false});
    redraw();
}
function gcp(e){const r=canvas.getBoundingClientRect();return{x:(e.clientX-r.left)*(canvas._w/r.width)-vpX,y:(e.clientY-r.top)*(canvas._h/r.height)-vpY};}
function sn(v){return Math.round(v/GCS)*GCS;}
function di(a,b){return Math.sqrt((a.x-b.x)**2+(a.y-b.y)**2);}
function fd(a,b){const dx=Math.abs(b.x-a.x)/GCS,dy=Math.abs(b.y-a.y)/GCS;return Math.round(Math.sqrt(dx*dx+dy*dy)*GS);}

/* ======== TOUCH (improved: 2-finger pan/pinch, better tap detection) ======== */
let lastTap=0;
let touchStartPos=null,touchMoved=false;
function tpScreen(e,idx){const r=canvas.getBoundingClientRect();const t=idx!==undefined?e.touches[idx]:(e.touches[0]||e.changedTouches[0]);if(!t)return null;return{sx:t.clientX,sy:t.clientY,x:(t.clientX-r.left)*(canvas._w/r.width),y:(t.clientY-r.top)*(canvas._h/r.height)};}
function tp(e){const r=canvas.getBoundingClientRect();const t=e.touches[0]||e.changedTouches[0];if(!t)return{x:0,y:0};return{x:(t.clientX-r.left)*(canvas._w/r.width)-vpX,y:(t.clientY-r.top)*(canvas._h/r.height)-vpY};}
function onTS(e){e.preventDefault();
    /* Two-finger: start pan/pinch */
    if(e.touches.length===2){const t0=tpScreen(e,0),t1=tpScreen(e,1);if(t0&&t1){pinchDist=Math.sqrt((t1.sx-t0.sx)**2+(t1.sy-t0.sy)**2);pinchMid={sx:(t0.sx+t1.sx)/2,sy:(t0.sy+t1.sy)/2};isPanning=true;panStart={x:vpX,y:vpY};}return;}
    /* Single finger in pan mode */
    if(gridMode==='pan'){const raw=tpScreen(e);if(raw){isPanning=true;panStart={x:vpX,y:vpY,sx:raw.sx,sy:raw.sy};}return;}
    /* Single finger draw mode */
    const p=tp(e);touchStartPos={x:p.x,y:p.y};touchMoved=false;
    if(tool==='house'||tool==='pool'){dragS={x:sn(p.x),y:sn(p.y)};}
}
function onTM(e){e.preventDefault();
    /* Two-finger pan/pinch */
    if(e.touches.length===2&&isPanning){const t0=tpScreen(e,0),t1=tpScreen(e,1);if(t0&&t1){
        const newMidSx=(t0.sx+t1.sx)/2,newMidSy=(t0.sy+t1.sy)/2;
        vpX=panStart.x+(newMidSx-pinchMid.sx);vpY=panStart.y+(newMidSy-pinchMid.sy);
        /* Pinch zoom */
        const nd=Math.sqrt((t1.sx-t0.sx)**2+(t1.sy-t0.sy)**2);
        if(pinchDist>0&&Math.abs(nd-pinchDist)>30){
            if(nd>pinchDist&&GCS<40){GCS+=2;GS=Math.round(GCS/4)||1;}
            else if(nd<pinchDist&&GCS>8){GCS-=2;GS=Math.round(GCS/4)||1;}
            pinchDist=nd;}
        redraw();}return;}
    /* Single finger pan mode */
    if(gridMode==='pan'&&isPanning&&panStart){const raw=tpScreen(e);if(raw){vpX=panStart.x+(raw.sx-panStart.sx);vpY=panStart.y+(raw.sy-panStart.sy);redraw();}return;}
    /* Draw mode move */
    touchMoved=true;
    const p=tp(e);const sx=sn(p.x),sy=sn(p.y);redraw();
    if((tool==='fence'||tool==='propline'||tool==='existing')&&cfp.length>0)drawPL(cfp[cfp.length-1],{x:sx,y:sy},tool==='propline'?'#94a3b8':tool==='existing'?'#ef4444':undefined);
    if((tool==='house'||tool==='pool')&&dragS){const color=tool==='pool'?'rgba(59,130,246,0.3)':'rgba(100,130,180,0.3)';ctx.fillStyle=color;const w=Math.abs(sx-dragS.x),h=Math.abs(sy-dragS.y);ctx.fillRect(Math.min(dragS.x,sx),Math.min(dragS.y,sy),w,h);}
}
function onTE(e){e.preventDefault();
    if(isPanning){isPanning=false;panStart=null;pinchDist=0;return;}
    if(gridMode==='pan')return;
    const p=tp(e);const sx=sn(p.x),sy=sn(p.y);const now=Date.now();
    /* Prevent tap if finger moved significantly */
    if(touchStartPos&&touchMoved){const dx=Math.abs(p.x-touchStartPos.x),dy=Math.abs(p.y-touchStartPos.y);if(Math.sqrt(dx*dx+dy*dy)>GCS*2){touchStartPos=null;dragS=null;return;}}
    if(now-lastTap<300&&(tool==='fence'||tool==='propline'||tool==='existing')&&cfp.length>=2){finLine();lastTap=0;return;}
    lastTap=now;
    if((tool==='house'||tool==='pool')&&dragS){const w=Math.abs(sx-dragS.x),h=Math.abs(sy-dragS.y);
        if(w>=GCS&&h>=GCS){su();
            if(tool==='house'){const lb=prompt('Label (House, Garage, Shed):')||'House';objs.push({type:'house',x:Math.min(dragS.x,sx),y:Math.min(dragS.y,sy),w,h,label:lb});}
            else{objs.push({type:'pool',x:Math.min(dragS.x,sx),y:Math.min(dragS.y,sy),w,h});}
            redraw();updateQ();asd();}dragS=null;return;}
    doClick(sx,sy);
}

/* ======== GATE MODAL ======== */
let pendingGate=null;let selGateWidth=4;
function openGM(x,y,type,suggestedDir){
    pendingGate={x,y,type,suggestedDir:suggestedDir||null};
    $('gate-modal-title').textContent=type==='gate-walk'?'Place Walk Gate (3-6 ft)':'Place Double Gate (10-16 ft)';
    /* Set width options based on gate type */
    const wo=$('gate-width-options');
    if(type==='gate-drive'){
        wo.innerHTML='<button type="button" class="gate-width-btn" data-width="10">10 ft</button><button type="button" class="gate-width-btn active" data-width="12">12 ft</button><button type="button" class="gate-width-btn" data-width="14">14 ft</button><button type="button" class="gate-width-btn" data-width="16">16 ft</button>';
        selGateWidth=12;
    }else{
        wo.innerHTML='<button type="button" class="gate-width-btn" data-width="3">3 ft</button><button type="button" class="gate-width-btn active" data-width="4">4 ft</button><button type="button" class="gate-width-btn" data-width="5">5 ft</button><button type="button" class="gate-width-btn" data-width="6">6 ft</button>';
        selGateWidth=4;
    }
    wo.querySelectorAll('.gate-width-btn').forEach(b=>{b.addEventListener('click',()=>{wo.querySelectorAll('.gate-width-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');selGateWidth=parseInt(b.dataset.width);});});
    /* Pre-select suggested direction if snapped to fence */
    if(pendingGate.suggestedDir){
        document.querySelectorAll('.gate-dir-btn').forEach(b=>{
            b.classList.toggle('suggested',b.dataset.dir===pendingGate.suggestedDir);
        });
    }else{document.querySelectorAll('.gate-dir-btn').forEach(b=>b.classList.remove('suggested'));}
    $('gate-modal').style.display='flex';
}
document.querySelectorAll('.gate-dir-btn').forEach(b=>{b.addEventListener('click',()=>{
    if(!pendingGate)return;
    su();
    if(pendingGate.fromMap&&window._onMapGateConfirmed){
        window._onMapGateConfirmed(b.dataset.dir,selGateWidth);
    }else{
        objs.push({type:pendingGate.type,x:pendingGate.x,y:pendingGate.y,dir:b.dataset.dir,width:selGateWidth});
        redraw();pendingGate=null;
    }
    $('gate-modal').style.display='none';updateQ();asd();
});});
$('gate-modal-cancel').addEventListener('click',()=>{$('gate-modal').style.display='none';pendingGate=null;});

/* Find closest point on any fence segment */
function snapGateToFence(x,y){
    let best=null,bestDist=Infinity;
    objs.forEach(o=>{
        if(o.type!=='fence')return;
        for(let i=0;i<o.points.length-1;i++){
            const a=o.points[i],b=o.points[i+1];
            /* Project point onto line segment */
            const dx=b.x-a.x,dy=b.y-a.y,len2=dx*dx+dy*dy;
            if(len2===0)continue;
            let t=((x-a.x)*dx+(y-a.y)*dy)/len2;
            t=Math.max(0,Math.min(1,t));
            const px=a.x+t*dx,py=a.y+t*dy;
            const d=Math.sqrt((x-px)**2+(y-py)**2);
            if(d<bestDist){bestDist=d;
                /* Auto-detect gate direction from fence angle */
                const angle=Math.atan2(dy,dx);
                const isVert=Math.abs(Math.sin(angle))>Math.abs(Math.cos(angle));
                let dir;
                if(isVert){dir=(x<px)?'left':'right';}
                else{dir=(y<py)?'up':'down';}
                best={x:sn(px),y:sn(py),dir,dist:d};
            }
        }
    });
    /* Snap if within 3 grid cells */
    if(best&&best.dist<GCS*3)return best;
    return null;
}

function doClick(x,y){
    if(tool==='fence'||tool==='propline'||tool==='existing'){cfp.push({x,y});redraw();return;}
    if(tool==='gate-walk'||tool==='gate-drive'){
        /* Try to snap gate to nearest fence line */
        const snap=snapGateToFence(x,y);
        if(snap){openGM(snap.x,snap.y,tool,snap.dir);}
        else{openGM(x,y,tool);}
        return;
    }
    if(tool==='tree'){su();objs.push({type:'tree',x,y});redraw();asd();return;}
    if(tool==='text'){openTM(x,y);return;}
    if(tool==='pool'||tool==='house'){return;} /* handled by drag */
    if(tool==='erase'){const o=findAt(x,y);if(o){su();objs.splice(objs.indexOf(o),1);redraw();updateQ();asd();}return;}
}

/* ======== TOOLS ======== */
document.querySelectorAll('.draw-tool').forEach(btn=>{btn.addEventListener('click',()=>{finLine();document.querySelectorAll('.draw-tool').forEach(b=>b.classList.remove('active'));btn.classList.add('active');tool=btn.dataset.tool;if(window._syncMapTool)window._syncMapTool();});});

/* ======== MOUSE ======== */
function snapPt(px,py){
    let sx=sn(px),sy=sn(py);
    if(shiftHeld&&cfp.length>0){const lp=cfp[cfp.length-1];if(Math.abs(sx-lp.x)>Math.abs(sy-lp.y))sy=lp.y;else sx=lp.x;}
    return{x:sx,y:sy};
}
function onClick(e){if(gridMode==='pan')return;const p=gcp(e);const sp=snapPt(p.x,p.y);doClick(sp.x,sp.y);}
function onDown(e){
    /* Middle-click or pan mode: start panning */
    if(e.button===1||gridMode==='pan'){e.preventDefault();isPanning=true;panStart={x:vpX,y:vpY,mx:e.clientX,my:e.clientY};canvas.style.cursor='grabbing';return;}
    if(gridMode==='pan')return;
    const p=gcp(e);
    /* Check if clicking on a gate to drag it */
    if(tool==='erase'||tool==='fence'||tool==='propline'||tool==='existing'){
        const g=objs.find(o=>(o.type==='gate-walk'||o.type==='gate-drive')&&Math.abs(o.x-sn(p.x))<=GCS&&Math.abs(o.y-sn(p.y))<=GCS);
        if(g){dragGate=g;dragGateStart={x:g.x,y:g.y};canvas.style.cursor='grabbing';return;}
    }
    if(tool==='house'||tool==='pool'){dragS={x:sn(p.x),y:sn(p.y)};}
}
let dragGate=null,dragGateStart=null;
function onUp(e){
    if(isPanning){isPanning=false;panStart=null;canvas.style.cursor=gridMode==='pan'?'grab':'crosshair';return;}
    if(gridMode==='pan')return;
    if(dragGate){dragGate=null;dragGateStart=null;canvas.style.cursor='crosshair';redraw();asd();return;}
    if((tool==='house'||tool==='pool')&&dragS){const p=gcp(e);const ex=sn(p.x),ey=sn(p.y);const w=Math.abs(ex-dragS.x),h=Math.abs(ey-dragS.y);
    if(w>=GCS&&h>=GCS){su();
        if(tool==='house'){const lb=prompt('Label (House, Garage, Shed):')||'House';objs.push({type:'house',x:Math.min(dragS.x,ex),y:Math.min(dragS.y,ey),w,h,label:lb});}
        else{objs.push({type:'pool',x:Math.min(dragS.x,ex),y:Math.min(dragS.y,ey),w,h});}
        redraw();updateQ();asd();}dragS=null;}}
function onMove(e){
    if(isPanning&&panStart){vpX=panStart.x+(e.clientX-panStart.mx);vpY=panStart.y+(e.clientY-panStart.my);redraw();return;}
    if(gridMode==='pan'){canvas.style.cursor='grab';return;}
    const p=gcp(e);const mx=p.x,my=p.y;const sp=snapPt(mx,my);if(dragGate){dragGate.x=sp.x;dragGate.y=sp.y;redraw();return;}redraw();
    if((tool==='fence'||tool==='propline'||tool==='existing')&&cfp.length>0){drawPL(cfp[cfp.length-1],sp,tool==='propline'?'#94a3b8':tool==='existing'?'#ef4444':'rgba(212,175,55,0.5)');drawSP(sp.x,sp.y,tool==='propline'?'rgba(148,163,184,0.5)':tool==='existing'?'rgba(239,68,68,0.5)':'rgba(212,175,55,0.5)');}
    if((tool==='house'||tool==='pool')&&dragS){const color=tool==='pool'?'rgba(59,130,246,0.3)':'rgba(100,130,180,0.3)';ctx.fillStyle=color;const sx=sn(sp.x),sy=sn(sp.y);const w=Math.abs(sx-dragS.x),h=Math.abs(sy-dragS.y);ctx.fillRect(Math.min(dragS.x,sx),Math.min(dragS.y,sy),w,h);ctx.strokeStyle=tool==='pool'?'#3b82f6':'#4682B4';ctx.lineWidth=2;ctx.strokeRect(Math.min(dragS.x,sx),Math.min(dragS.y,sy),w,h);}
    if(tool==='gate-walk'||tool==='gate-drive'){
        const snap=snapGateToFence(sp.x,sp.y);
        if(snap){drawSP(snap.x,snap.y,'#10b981');ctx.beginPath();ctx.setLineDash([4,3]);ctx.moveTo(sp.x,sp.y);ctx.lineTo(snap.x,snap.y);ctx.strokeStyle='#10b981';ctx.lineWidth=1;ctx.stroke();ctx.setLineDash([]);ctx.font='bold 9px sans-serif';ctx.fillStyle='#10b981';ctx.fillText('⚡ snap',snap.x+8,snap.y-8);}
        else drawSP(sp.x,sp.y,'rgba(16,185,129,0.5)');
    }
    if(tool==='tree'){ctx.beginPath();ctx.arc(sp.x,sp.y,GCS*0.8,0,Math.PI*2);ctx.fillStyle='rgba(34,139,34,0.3)';ctx.fill();}
    if(tool==='erase')canvas.style.cursor=findAt(mx,my)?'pointer':'crosshair';
}
function onDbl(e){
    if(gridMode==='pan')return;
    const p=gcp(e);const o=findAt(p.x,p.y);
    if(o&&(o.type==='gate-walk'||o.type==='gate-drive')){const dirs=['right','down','left','up'];const ci=dirs.indexOf(o.dir||'right');o.dir=dirs[(ci+1)%4];redraw();asd();e.stopPropagation();return;}
    if((tool==='fence'||tool==='propline'||tool==='existing')&&cfp.length>=2)finLine();
}

function drawPL(from,to,color){const c2=color||'rgba(212,175,55,0.5)';ctx.beginPath();ctx.moveTo(from.x,from.y);ctx.lineTo(to.x,to.y);ctx.strokeStyle=c2;ctx.lineWidth=2;ctx.setLineDash([5,5]);ctx.stroke();ctx.setLineDash([]);
    const d=fd(from,to);if(d>0){ctx.font='bold 12px sans-serif';ctx.fillStyle=c2.replace(',0.5)',',1)').replace('rgba','rgb');ctx.fillText(d+'ft',(from.x+to.x)/2+5,(from.y+to.y)/2-8);}}
function drawPR(from,to){const sx=sn(to.x),sy=sn(to.y);const w=Math.abs(sx-from.x),h=Math.abs(sy-from.y);ctx.fillStyle='rgba(100,130,180,0.3)';ctx.strokeStyle='#4682B4';ctx.lineWidth=2;
    ctx.fillRect(Math.min(from.x,sx),Math.min(from.y,sy),w,h);ctx.strokeRect(Math.min(from.x,sx),Math.min(from.y,sy),w,h);
    ctx.font='11px sans-serif';ctx.fillStyle='#4682B4';ctx.fillText(Math.round(w/GCS*GS)+'×'+Math.round(h/GCS*GS)+'ft',Math.min(from.x,sx)+4,Math.min(from.y,sy)-4);}

function finLine(){if(cfp.length>=2){su();const segs=[];for(let i=0;i<cfp.length-1;i++)segs.push({dist:fd(cfp[i],cfp[i+1])});
    if(tool==='fence')objs.push({type:'fence',points:[...cfp],fenceType:{...selFence},segments:segs});
    else if(tool==='propline')objs.push({type:'propline',points:[...cfp],segments:segs});
    else if(tool==='existing')objs.push({type:'existing',points:[...cfp],segments:segs});
    updateQ();asd();}cfp=[];redraw();}
function finFence(){finLine();}

function findAt(mx,my){for(let i=objs.length-1;i>=0;i--){const o=objs[i];
    if(o.type==='fence'||o.type==='propline'||o.type==='existing'){for(let j=0;j<o.points.length-1;j++){if(dts(mx,my,o.points[j],o.points[j+1])<10)return o;}}
    if(o.type==='gate-walk'||o.type==='gate-drive'){if(di({x:mx,y:my},o)<GCS*1.2)return o;}
    if(o.type==='tree'){if(di({x:mx,y:my},o)<GCS)return o;}
    if(o.type==='house'||o.type==='pool'){if(mx>=o.x&&mx<=o.x+o.w&&my>=o.y&&my<=o.y+o.h)return o;}
    if(o.type==='text'){if(mx>=o.x-5&&mx<=o.x+100&&my>=o.y-15&&my<=o.y+5)return o;}}return null;}
function dts(px,py,a,b){const dx=b.x-a.x,dy=b.y-a.y,l2=dx*dx+dy*dy;if(l2===0)return di({x:px,y:py},a);let t=((px-a.x)*dx+(py-a.y)*dy)/l2;t=Math.max(0,Math.min(1,t));return di({x:px,y:py},{x:a.x+t*dx,y:a.y+t*dy});}

/* ======== RENDER ======== */
function drawGrid(){const w=canvas._w,h=canvas._h;ctx.fillStyle='#f8fafc';ctx.fillRect(-vpX,-vpY,w,h);ctx.strokeStyle='#e8ecf0';ctx.lineWidth=0.5;
    /* Draw grid lines extended for pan offset */
    const startX=Math.floor((-vpX)/GCS)*GCS,endX=startX+w+GCS*2;
    const startY=Math.floor((-vpY)/GCS)*GCS,endY=startY+h+GCS*2;
    for(let x=startX;x<=endX;x+=GCS){ctx.beginPath();ctx.moveTo(x,startY);ctx.lineTo(x,endY);ctx.stroke();}
    for(let y=startY;y<=endY;y+=GCS){ctx.beginPath();ctx.moveTo(startX,y);ctx.lineTo(endX,y);ctx.stroke();}
    ctx.font='10px sans-serif';ctx.fillStyle='#b0b8c4';ctx.fillText('1 sq = '+GS+' ft',4-vpX,h-4-vpY);}
function drawSP(x,y,c){ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fillStyle=c;ctx.fill();}

function redraw(){if(!ctx)return;const dpr=window.devicePixelRatio||1;ctx.setTransform(dpr,0,0,dpr,vpX*dpr,vpY*dpr);drawGrid();
    objs.forEach(o=>{if(o.type==='house')drawHouse(o);if(o.type==='pool')drawPool(o);});
    objs.forEach(o=>{if(o.type==='propline')drawPropLine(o);if(o.type==='existing')drawExisting(o);});
    objs.forEach(o=>{if(o.type==='fence')drawFL(o);});
    objs.forEach(o=>{
        if(o.type==='gate-walk')drawGate(o,'Walk Gate','#10b981',GCS*0.7);
        if(o.type==='gate-drive')drawGate(o,'Dbl Gate','#3b82f6',GCS*1.0);
        if(o.type==='tree')drawTr(o);if(o.type==='text')drawTx(o);});
    if(cfp.length>0){const lc=tool==='propline'?'#94a3b8':tool==='existing'?'#ef4444':selFence?.color||'#d4af37';
        ctx.beginPath();ctx.moveTo(cfp[0].x,cfp[0].y);for(let i=1;i<cfp.length;i++)ctx.lineTo(cfp[i].x,cfp[i].y);
        if(tool==='propline'){ctx.setLineDash([8,6]);ctx.strokeStyle='#94a3b8';ctx.lineWidth=2;ctx.stroke();ctx.setLineDash([]);}
        else if(tool==='existing'){ctx.setLineDash([6,4]);ctx.strokeStyle='#ef4444';ctx.lineWidth=3;ctx.stroke();ctx.setLineDash([]);}
        else{ctx.strokeStyle=lc;ctx.lineWidth=4;ctx.stroke();}
        cfp.forEach((p,i)=>drawSP(p.x,p.y,i===0?'#10b981':lc));
        for(let i=0;i<cfp.length-1;i++){const a=cfp[i],b=cfp[i+1];ctx.font='bold 10px sans-serif';ctx.fillStyle='#1e3a5f';ctx.fillText(fd(a,b)+'ft',(a.x+b.x)/2+4,(a.y+b.y)/2-6);}}
    let tf=0;objs.forEach(o=>{if(o.type==='fence')o.segments.forEach(s=>tf+=s.dist);});
    const gd=$('grid-total-display');if(gd)gd.textContent='Total: '+tf+' ft';
}

function drawFL(o){if(o.points.length<2)return;ctx.beginPath();ctx.moveTo(o.points[0].x,o.points[0].y);for(let i=1;i<o.points.length;i++)ctx.lineTo(o.points[i].x,o.points[i].y);ctx.strokeStyle=o.fenceType.color;ctx.lineWidth=4;ctx.stroke();
    if(o.fenceType.name.includes('Chain')){ctx.setLineDash([6,4]);ctx.strokeStyle='rgba(255,255,255,0.4)';ctx.lineWidth=2;ctx.stroke();ctx.setLineDash([]);}
    o.points.forEach(p=>drawSP(p.x,p.y,o.fenceType.color));
    for(let i=0;i<o.points.length-1;i++){const a=o.points[i],b=o.points[i+1];ctx.font='bold 10px sans-serif';ctx.fillStyle='#1e3a5f';ctx.fillText(o.segments[i].dist+'ft',(a.x+b.x)/2+4,(a.y+b.y)/2-6);}
    const m={x:(o.points[0].x+o.points[1].x)/2,y:(o.points[0].y+o.points[1].y)/2};ctx.font='9px sans-serif';ctx.fillStyle='rgba(30,58,95,0.7)';ctx.fillText(o.fenceType.name,m.x+4,m.y+14);}

/* ======== ARCHITECTURAL GATES (4-direction + custom width) ======== */
function drawGate(o,label,color,defaultRadius){
    const dir=o.dir||'right';
    /* Use stored width if available, otherwise default */
    const widthFt=o.width||(o.type==='gate-drive'?12:4);
    const radius=Math.max(defaultRadius,(widthFt/GS)*GCS*0.5);
    const gw=radius*2;
    const vert=(dir==='up'||dir==='down');
    ctx.save();ctx.translate(o.x,o.y);
    ctx.strokeStyle=color;ctx.lineWidth=2;
    if(vert){
        ctx.beginPath();ctx.moveTo(-6,-radius);ctx.lineTo(6,-radius);ctx.stroke();
        ctx.beginPath();ctx.moveTo(-6,radius);ctx.lineTo(6,radius);ctx.stroke();
        ctx.fillStyle=color+'22';ctx.strokeStyle=color;ctx.lineWidth=1.5;
        ctx.fillRect(-2,-radius,4,gw);ctx.strokeRect(-2,-radius,4,gw);
        ctx.setLineDash([4,4]);ctx.strokeStyle=color+'66';ctx.lineWidth=1;
        if(dir==='down'){ctx.beginPath();ctx.arc(0,-radius,gw,Math.PI/2,0,true);ctx.stroke();ctx.beginPath();ctx.arc(0,-radius,3,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();}
        else{ctx.beginPath();ctx.arc(0,radius,gw,-Math.PI/2,0,false);ctx.stroke();ctx.beginPath();ctx.arc(0,radius,3,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();}
    }else{
        ctx.beginPath();ctx.moveTo(-radius,-6);ctx.lineTo(-radius,6);ctx.stroke();
        ctx.beginPath();ctx.moveTo(radius,-6);ctx.lineTo(radius,6);ctx.stroke();
        ctx.fillStyle=color+'22';ctx.strokeStyle=color;ctx.lineWidth=1.5;
        ctx.fillRect(-radius,-2,gw,4);ctx.strokeRect(-radius,-2,gw,4);
        ctx.setLineDash([4,4]);ctx.strokeStyle=color+'66';ctx.lineWidth=1;
        if(dir==='right'){ctx.beginPath();ctx.arc(-radius,0,gw,0,-Math.PI/2,true);ctx.stroke();ctx.beginPath();ctx.arc(-radius,0,3,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();}
        else{ctx.beginPath();ctx.arc(radius,0,gw,-Math.PI,-Math.PI/2,false);ctx.stroke();ctx.beginPath();ctx.arc(radius,0,3,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();}
    }
    ctx.setLineDash([]);
    ctx.font='bold 9px sans-serif';ctx.fillStyle=color;ctx.textAlign='center';
    ctx.fillText(label+' ('+widthFt+'ft)',0,radius+14);
    ctx.font='7px sans-serif';ctx.fillStyle=color+'88';ctx.fillText('dbl-click to rotate',0,radius+23);
    ctx.textAlign='left';ctx.restore();
}

function drawTr(o){ctx.beginPath();ctx.arc(o.x,o.y,GCS*0.8,0,Math.PI*2);ctx.fillStyle='rgba(34,139,34,0.35)';ctx.fill();ctx.strokeStyle='#228B22';ctx.lineWidth=1.5;ctx.stroke();ctx.beginPath();ctx.arc(o.x,o.y,3,0,Math.PI*2);ctx.fillStyle='#5C4033';ctx.fill();}
function drawHouse(o){ctx.fillStyle='rgba(70,100,140,0.15)';ctx.fillRect(o.x,o.y,o.w,o.h);ctx.strokeStyle='#4682B4';ctx.lineWidth=2;ctx.strokeRect(o.x,o.y,o.w,o.h);
    ctx.strokeStyle='rgba(70,130,180,0.2)';ctx.lineWidth=1;for(let d=-o.h;d<o.w;d+=GCS){ctx.beginPath();ctx.moveTo(Math.max(o.x,o.x+d),d<0?o.y-d+o.y:o.y);ctx.lineTo(Math.min(o.x+o.w,o.x+d+o.h),d+o.h<o.w?o.y+o.h:o.y+o.w-d);ctx.stroke();}
    ctx.font='bold 11px sans-serif';ctx.fillStyle='#4682B4';ctx.textAlign='center';ctx.fillText(o.label||'House',o.x+o.w/2,o.y+o.h/2+4);ctx.textAlign='left';
    ctx.font='9px sans-serif';ctx.fillStyle='rgba(70,130,180,0.6)';ctx.fillText(Math.round(o.w/GCS*GS)+'×'+Math.round(o.h/GCS*GS)+'ft',o.x+4,o.y+14);}
function drawTx(o){ctx.font='bold 12px sans-serif';ctx.fillStyle='#6b21a8';ctx.fillText(o.text,o.x,o.y);ctx.beginPath();ctx.arc(o.x-4,o.y-4,2,0,Math.PI*2);ctx.fillStyle='#6b21a8';ctx.fill();}

function drawPropLine(o){if(o.points.length<2)return;ctx.beginPath();ctx.moveTo(o.points[0].x,o.points[0].y);for(let i=1;i<o.points.length;i++)ctx.lineTo(o.points[i].x,o.points[i].y);
    ctx.setLineDash([8,6]);ctx.strokeStyle='#94a3b8';ctx.lineWidth=2;ctx.stroke();ctx.setLineDash([]);
    o.points.forEach(p=>{ctx.beginPath();ctx.arc(p.x,p.y,3,0,Math.PI*2);ctx.fillStyle='#94a3b8';ctx.fill();});
    for(let i=0;i<o.points.length-1;i++){const a=o.points[i],b=o.points[i+1];ctx.font='9px sans-serif';ctx.fillStyle='#94a3b8';ctx.fillText(o.segments[i].dist+'ft',(a.x+b.x)/2+4,(a.y+b.y)/2+14);}
    ctx.font='8px sans-serif';ctx.fillStyle='#94a3b8';ctx.fillText('PROP LINE',o.points[0].x+4,o.points[0].y-8);}

function drawExisting(o){if(o.points.length<2)return;ctx.beginPath();ctx.moveTo(o.points[0].x,o.points[0].y);for(let i=1;i<o.points.length;i++)ctx.lineTo(o.points[i].x,o.points[i].y);
    ctx.setLineDash([6,4]);ctx.strokeStyle='#ef4444';ctx.lineWidth=3;ctx.stroke();ctx.setLineDash([]);
    /* X marks along existing fence */
    for(let i=0;i<o.points.length-1;i++){const a=o.points[i],b=o.points[i+1];const mx=(a.x+b.x)/2,my=(a.y+b.y)/2;
        ctx.strokeStyle='#ef4444';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(mx-4,my-4);ctx.lineTo(mx+4,my+4);ctx.stroke();ctx.beginPath();ctx.moveTo(mx+4,my-4);ctx.lineTo(mx-4,my+4);ctx.stroke();
        ctx.font='bold 9px sans-serif';ctx.fillStyle='#dc2626';ctx.fillText(o.segments[i].dist+'ft',(a.x+b.x)/2+8,(a.y+b.y)/2-6);}
    ctx.font='8px sans-serif';ctx.fillStyle='#ef4444';ctx.fillText('REMOVE',o.points[0].x+4,o.points[0].y-8);}

function drawPool(o){
    ctx.fillStyle='rgba(59,130,246,0.12)';ctx.fillRect(o.x,o.y,o.w,o.h);
    ctx.strokeStyle='#3b82f6';ctx.lineWidth=2;ctx.setLineDash([6,4]);ctx.strokeRect(o.x,o.y,o.w,o.h);ctx.setLineDash([]);
    /* Water wave pattern */
    ctx.strokeStyle='rgba(59,130,246,0.3)';ctx.lineWidth=1;
    for(let y=o.y+GCS;y<o.y+o.h;y+=GCS){ctx.beginPath();for(let x=o.x;x<=o.x+o.w;x+=4){ctx.lineTo(x,y+Math.sin((x-o.x)/8)*3);}ctx.stroke();}
    ctx.font='bold 10px sans-serif';ctx.fillStyle='#3b82f6';ctx.textAlign='center';ctx.fillText('POOL',o.x+o.w/2,o.y+o.h/2+4);
    ctx.font='8px sans-serif';ctx.fillText(Math.round(o.w/GCS*GS)+'×'+Math.round(o.h/GCS*GS)+'ft',o.x+o.w/2,o.y+o.h/2+16);
    ctx.textAlign='left';}

/* ======== TEXT MODAL ======== */
let tPos=null;
function openTM(x,y){tPos={x,y};$('text-modal').style.display='flex';$('text-modal-input').value='';$('text-modal-input').focus();}
$('text-modal-cancel').addEventListener('click',()=>{$('text-modal').style.display='none';tPos=null;});
$('text-modal-ok').addEventListener('click',()=>{const t=$('text-modal-input').value.trim();if(t&&tPos){su();objs.push({type:'text',x:tPos.x,y:tPos.y,text:t});redraw();asd();}$('text-modal').style.display='none';tPos=null;});
$('text-modal-input').addEventListener('keypress',e=>{if(e.key==='Enter')$('text-modal-ok').click();});

/* ======== UNDO ======== */
function su(){undo.push(JSON.stringify(objs));}
$('grid-finish')?.addEventListener('click',()=>{finLine();});
$('grid-undo').addEventListener('click',()=>{if(cfp.length>0){cfp.pop();redraw();return;}if(undo.length){objs=JSON.parse(undo.pop());redraw();updateQ();asd();}});
$('grid-clear').addEventListener('click',()=>{if(!confirm('Clear entire drawing?'))return;su();objs=[];cfp=[];redraw();updateQ();asd();});

/* ======== ZOOM ======== */
$('grid-zoom-in')?.addEventListener('click',()=>{if(GCS<40){GCS+=4;GS=Math.round(GCS/4)||1;redraw();}});
$('grid-zoom-out')?.addEventListener('click',()=>{if(GCS>8){GCS-=4;GS=Math.round(GCS/4)||1;redraw();}});

/* Scroll-wheel zoom (listener in initCanvas) */

/* Draw/Pan mode toggle */
$('grid-mode-draw')?.addEventListener('click',()=>{gridMode='draw';$('grid-mode-draw').classList.add('active');$('grid-mode-pan').classList.remove('active');canvas.style.cursor='crosshair';});
$('grid-mode-pan')?.addEventListener('click',()=>{gridMode='pan';finLine();$('grid-mode-pan').classList.add('active');$('grid-mode-draw').classList.remove('active');canvas.style.cursor='grab';});

/* Reset view */
$('grid-reset-view')?.addEventListener('click',()=>{vpX=0;vpY=0;GCS=Math.max(14,Math.floor(canvas._w/40));GS=Math.round(GCS/4)||1;redraw();});

/* Keyboard shortcut: Space to toggle pan mode */
document.addEventListener('keydown',e=>{if(e.code==='Space'&&document.activeElement?.tagName!=='INPUT'&&document.activeElement?.tagName!=='TEXTAREA'){e.preventDefault();$('grid-mode-pan')?.click();}});
document.addEventListener('keyup',e=>{if(e.code==='Space'&&gridMode==='pan'){$('grid-mode-draw')?.click();}});

/* ======== DOWNLOAD ======== */
$('grid-download')?.addEventListener('click',()=>{
    /* Save current viewport, reset for clean screenshot */
    const savedVpX=vpX,savedVpY=vpY;vpX=0;vpY=0;redraw();
    const link=document.createElement('a');link.download='fence-layout-'+new Date().toISOString().split('T')[0]+'.png';
    const tmpCanvas=document.createElement('canvas');tmpCanvas.width=canvas.width;tmpCanvas.height=canvas.height;
    const tmpCtx=tmpCanvas.getContext('2d');tmpCtx.drawImage(canvas,0,0);
    const dpr=window.devicePixelRatio||1;tmpCtx.font='bold '+(14*dpr)+'px sans-serif';tmpCtx.fillStyle='rgba(30,58,95,0.3)';
    tmpCtx.fillText('Ghareeb Fencing Solutions · (419) 902-8257',10*dpr,(canvas._h-10)*dpr);
    link.href=tmpCanvas.toDataURL('image/png');link.click();
    /* Restore viewport */
    vpX=savedVpX;vpY=savedVpY;redraw();
});

/* ======== QUOTE CALC ======== */
function updateQ(){
    const fences={},gates={walk:0,drive:0};let totalFt=0;let existingFt=0;let propFt=0;let hasPool=false;
    objs.forEach(o=>{
        if(o.type==='fence'){const ft=o.segments.reduce((s,g)=>s+g.dist,0);const k=o.fenceType.name;if(!fences[k])fences[k]={ft:0,ppf:o.fenceType.ppf,sg:o.fenceType.sg,dg:o.fenceType.dg,color:o.fenceType.color};fences[k].ft+=ft;totalFt+=ft;}
        if(o.type==='gate-walk')gates.walk++;if(o.type==='gate-drive')gates.drive++;
        if(o.type==='gate-walk'||o.type==='gate-drive'){if(!gates.details)gates.details=[];gates.details.push({type:o.type,width:o.width||(o.type==='gate-drive'?12:4)});}
        if(o.type==='existing')existingFt+=o.segments.reduce((s,g)=>s+g.dist,0);
        if(o.type==='propline')propFt+=o.segments.reduce((s,g)=>s+g.dist,0);
        if(o.type==='pool')hasPool=true;
    });
    const mf=$('manual-feet')&&$('manual-feet').value?parseInt($('manual-feet').value):0;if(mf>0&&!totalFt)totalFt=mf;
    if(totalFt<10&&!Object.keys(fences).length){$('summary-placeholder').style.display='flex';$('summary-preview').style.display='none';$('drawing-legend').style.display='none';$('compare-btn').style.display='none';$('compare-section').style.display='none';return;}
    $('summary-placeholder').style.display='none';$('summary-preview').style.display='block';$('compare-btn').style.display='block';$('export-pdf-btn').style.display='block';
    const hm=HM[$('fence-height').value];
    /* Removal: combine drawn existing fence + manual input */
    const manualRemoval=parseInt($('removal-feet')?.value)||0;
    const totalRemoval=existingFt+manualRemoval;
    const isPool=hasPool||$('pool-area')?.checked;
    let gt=0,bh='';
    if(Object.keys(fences).length>0){for(const[n,f]of Object.entries(fences)){gt+=f.ft*f.ppf*hm;bh+=`<div class="summary-line"><span><span class="swatch" style="background:${f.color}"></span>${n}</span><span>${f.ft} ft</span></div>`;}}
    else if(mf>0&&selFence){gt=mf*selFence.ppf*hm;bh=`<div class="summary-line"><span><span class="swatch" style="background:${selFence.color}"></span>${selFence.name}</span><span>${mf} ft</span></div>`;}
    $('fence-breakdown').innerHTML=bh;
    let gh='';
    /* Gate pricing with width details */
    const walkGates=objs.filter(o=>o.type==='gate-walk');
    const driveGates=objs.filter(o=>o.type==='gate-drive');
    if(walkGates.length>0){const ff=Object.values(fences)[0]||selFence||pricingData[0];const baseC=ff.sg||350;walkGates.forEach(g=>{const w=g.width||4;const wm=w<=3?0.85:w===4?1:w===5?1.15:1.3;const c=Math.round(baseC*wm);gt+=c;gh+=`<div class="summary-line"><span>🚪 Walk Gate (${w}ft)</span><span>$${c.toLocaleString()}</span></div>`;});}
    if(driveGates.length>0){const ff=Object.values(fences)[0]||selFence||pricingData[0];const baseC=ff.dg||650;driveGates.forEach(g=>{const w=g.width||12;const wm=w<=10?0.85:w===12?1:w===14?1.15:1.3;const c=Math.round(baseC*wm);gt+=c;gh+=`<div class="summary-line"><span>🚗 Dbl Gate (${w}ft)</span><span>$${c.toLocaleString()}</span></div>`;});}
    $('gate-breakdown').innerHTML=gh;
    /* Existing fence line */
    const efl=$('existing-fence-line');if(efl){if(existingFt>0){efl.style.display='flex';$('existing-fence-ft').textContent=existingFt+' ft';}else efl.style.display='none';}
    /* Removal cost */
    if(totalRemoval>0){const rc=totalRemoval*4;gt+=rc;$('preview-removal-line').style.display='flex';$('removal-cost').textContent='+$'+rc.toLocaleString()+' ('+totalRemoval+'ft)';}else $('preview-removal-line').style.display='none';
    /* Pool compliance */
    const ppl=$('preview-pool-line');if(ppl){ppl.style.display=isPool?'flex':'none';}
    const pn=$('pool-note');if(pn)pn.style.display=isPool?'block':'none';
    /* Property line */
    const pls=$('propline-summary');if(pls){if(propFt>0){pls.style.display='flex';$('propline-ft').textContent=propFt+' ft';}else pls.style.display='none';}
    $('total-feet').innerHTML='<strong>'+totalFt+' ft</strong>';
    const lo=Math.round(gt*0.85),hi=Math.round(gt*1.15);
    $('range-low').textContent='$'+lo.toLocaleString();$('range-high').textContent='$'+hi.toLocaleString();
    /* Update mobile sticky bar */
    const mqb=$('mobile-quote-bar');if(mqb){if(lo>0){mqb.style.display='block';$('mqb-range').textContent='$'+lo.toLocaleString()+' — $'+hi.toLocaleString();$('mqb-ft').textContent=totalFt+' ft';}else{mqb.style.display='none';}}
    leadData.estimate={low:lo,high:hi,totalFt,fences,gates,height:$('fence-height').value,removal:totalRemoval>0,removalFt:totalRemoval,pool:isPool,existingFenceFt:existingFt,propertyLineFt:propFt};
    updateLeg(fences,gates,existingFt,propFt,hasPool);

    if(lo>0&&leadData.name){clearTimeout(window._qst);window._qst=setTimeout(()=>submitLead(leadData,'Ballpark: '+Object.keys(fences).join(', ')+', '+totalFt+'ft, $'+lo+'-$'+hi),3000);}
}

/* ======== COMPARE ======== */
$('compare-btn').addEventListener('click',()=>{const s=$('compare-section');s.style.display=s.style.display==='none'?'block':'none';if(s.style.display==='block'){renderCompare();s.scrollIntoView({behavior:'smooth',block:'start'});}});
function renderCompare(){
    let tf=0;objs.forEach(o=>{if(o.type==='fence')o.segments.forEach(s=>tf+=s.dist);});
    const mf=$('manual-feet')&&$('manual-feet').value?parseInt($('manual-feet').value):0;if(mf>0&&!tf)tf=mf;if(tf<10)tf=150;
    const hm=HM[$('fence-height').value];
    let h='<div class="compare-grid">';
    pricingData.forEach((s,idx)=>{const cost=Math.round(tf*s.ppf*hm);const lo=Math.round(cost*0.85),hi=Math.round(cost*1.15);const isSel=selFence&&selFence.name===s.name;
        h+=`<div class="compare-card${isSel?' compare-active':''}">`;
        h+=`<div class="compare-color" style="background:${s.color}"></div>`;
        if(s.img)h+=`<img src="${s.img}" alt="${s.name}" class="compare-img" crossorigin="anonymous" />`;
        h+=`<div class="compare-name">${s.name}</div>`;
        h+=`<div class="compare-price">$${lo.toLocaleString()} — $${hi.toLocaleString()}</div>`;
        h+=`<div class="compare-footage">${tf} linear ft</div>`;
        if(!isSel)h+=`<button class="compare-select-btn" onclick="document.getElementById('fence-style-dropdown').value='${idx}';document.getElementById('fence-style-dropdown').dispatchEvent(new Event('change'));document.getElementById('compare-section').style.display='none';">Select This Style</button>`;
        else h+=`<span class="compare-current">✓ Currently Selected</span>`;
        h+=`</div>`;});
    h+='</div>';$('compare-cards').innerHTML=h;
}

function updateLeg(fences,gates,existingFt,propFt,hasPool){const leg=$('drawing-legend'),items=$('legend-items'),photos=$('legend-style-photos');const has=objs.length>0;leg.style.display=has?'block':'none';if(!has)return;
    /* Style photos */
    let ph='';const styleNames=Object.keys(fences);
    if(styleNames.length>0){ph='<div class="legend-photos">';
        styleNames.forEach(n=>{const f=pricingData.find(p=>p.name===n);const img=f&&f.img?f.img:'';const color=fences[n].color;
            ph+=img?`<div class="legend-photo-card"><img src="${img}" alt="${n}" /><div class="legend-photo-info"><strong>${n}</strong><span>${fences[n].ft} ft</span></div></div>`
            :`<div class="legend-photo-card"><div class="legend-photo-swatch" style="background:${color}"></div><div class="legend-photo-info"><strong>${n}</strong><span>${fences[n].ft} ft</span></div></div>`;
        });ph+='</div>';}
    if(photos)photos.innerHTML=ph;
    /* Legend items */
    let h='';for(const[n,f]of Object.entries(fences))h+=`<div class="legend-row"><span class="swatch" style="background:${f.color}"></span><span>${n}: ${f.ft}ft</span></div>`;
