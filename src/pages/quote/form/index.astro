---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../../lib/firestore.js';
const site = await getSiteSettings();
---

<BaseLayout 
    title="Request a Detailed Quote | Ghareeb Fencing Solutions" 
    description="Submit a detailed fence quote request. Tell us about your project and we'll prepare a comprehensive estimate within 24 hours."
    canonical="/quote/form/"
>
    <section class="hero-mini">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a> / <a href="/quote/">Quote</a> / <span>Detailed Quote</span>
            </div>
            <h1 data-editable data-edit-doc="content/pages" data-edit-field="quoteForm.title">Request a Detailed Quote</h1>
            <p class="subtitle" data-editable data-edit-doc="content/pages" data-edit-field="quoteForm.subtitle">Tell us about your project and receive a comprehensive estimate within 24 hours</p>
        </div>
    </section>

    <section class="form-section">
        <div class="container">
            <!-- Hidden Netlify Form for backup lead capture -->
            <form name="detailed-quote-leads" netlify netlify-honeypot="bot-field" hidden>
                <input type="text" name="bot-field" />
                <input type="text" name="name" />
                <input type="tel" name="phone" />
                <input type="email" name="email" />
                <input type="text" name="address" />
                <input type="text" name="fenceType" />
                <textarea name="message"></textarea>
            </form>
            <div class="form-grid">
                <div class="form-main">
                    <form id="quote-form" novalidate>
                        <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true"><input type="text" name="website" id="hp-website" tabindex="-1" autocomplete="off" /></div>
                        <!-- Contact Info -->
                        <div class="form-card">
                            <h3>📋 Your Information</h3>
                            <div class="form-row">
                                <div class="form-group"><label for="q-name">Full Name *</label><input type="text" id="q-name" required placeholder="John Smith" /></div>
                                <div class="form-group"><label for="q-phone">Phone *</label><input type="tel" id="q-phone" required placeholder="(419) 555-1234" /></div>
                            </div>
                            <div class="form-row">
                                <div class="form-group"><label for="q-email">Email *</label><input type="email" id="q-email" required placeholder="john@email.com" /></div>
                                <div class="form-group"><label for="q-address">Property Address *</label><input type="text" id="q-address" required placeholder="123 Main St, Toledo, OH" /></div>
                            </div>
                        </div>

                        <!-- Project Details -->
                        <div class="form-card">
                            <h3>🏗️ Project Details</h3>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="q-type">Fence Type *</label>
                                    <select id="q-type" required>
                                        <option value="">Select fence type...</option>
                                        <option value="Cedar Privacy">Cedar Privacy Fence</option>
                                        <option value="Pressure-Treated Privacy">Pressure-Treated Wood Privacy</option>
                                        <option value="Wood Shadowbox">Wood Shadowbox Fence</option>
                                        <option value="White Vinyl Privacy">White Vinyl Privacy</option>
                                        <option value="Tan Vinyl Privacy">Tan Vinyl Privacy</option>
                                        <option value="Black Chain Link">Black Chain Link</option>
                                        <option value="Galvanized Chain Link">Galvanized Chain Link</option>
                                        <option value="Black Aluminum">Black Aluminum Ornamental</option>
                                        <option value="Bronze Aluminum">Bronze Aluminum Ornamental</option>
                                        <option value="Split Rail">Split Rail / Farm Fence</option>
                                        <option value="Not Sure">Not Sure - Need Advice</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="q-height">Preferred Height</label>
                                    <select id="q-height">
                                        <option value="">Not sure</option>
                                        <option value="4 ft">4 feet</option>
                                        <option value="5 ft">5 feet</option>
                                        <option value="6 ft">6 feet (standard)</option>
                                        <option value="8 ft">8 feet</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="q-length">Approximate Length (feet)</label>
                                    <input type="text" id="q-length" placeholder="e.g., 150 ft, or 'not sure'" />
                                </div>
                                <div class="form-group">
                                    <label for="q-timeline">Timeline</label>
                                    <select id="q-timeline">
                                        <option value="">When do you need this done?</option>
                                        <option value="ASAP">As soon as possible</option>
                                        <option value="1-2 weeks">Within 1-2 weeks</option>
                                        <option value="1 month">Within a month</option>
                                        <option value="2-3 months">2-3 months</option>
                                        <option value="Just planning">Just planning / getting quotes</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="q-gates">Gates (number & width)</label>
                                    <input type="text" id="q-gates" placeholder="e.g., 1 gate, 4ft wide" />
                                </div>
                                <div class="form-group">
                                    <label for="q-double-gates">Double Gates (number & width)</label>
                                    <input type="text" id="q-double-gates" placeholder="e.g., 1 double gate, 12ft wide" />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="q-removal">Existing Fence Removal (length & style)</label>
                                    <input type="text" id="q-removal" placeholder="e.g., 80ft chain link, 40ft wood" />
                                </div>
                                <div class="form-group" style="display:flex;align-items:end;padding-bottom:2px;">
                                    <label class="checkbox-label" style="margin-bottom:14px;"><input type="checkbox" id="q-pool" /> Pool area (code compliance needed)</label>
                                </div>
                            </div>
                        </div>

                        <!-- Additional Info -->
                        <div class="form-card">
                            <h3>💬 Anything Else?</h3>
                            <div class="form-group">
                                <label for="q-notes">Additional Notes or Questions</label>
                                <textarea id="q-notes" rows="4" placeholder="Describe your project, special requirements, questions, etc."></textarea>
                            </div>
                            <div class="form-group">
                                <label for="q-heard">How did you hear about us?</label>
                                <select id="q-heard">
                                    <option value="">Select...</option>
                                    <option value="Google">Google Search</option>
                                    <option value="Facebook">Facebook</option>
                                    <option value="Referral">Referral / Word of Mouth</option>
                                    <option value="Yard Sign">Saw Our Yard Sign</option>
                                    <option value="Repeat Customer">Repeat Customer</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>

                        <!-- Custom Fields (editable via Edit Mode) -->
                        <div id="custom-fields-section"></div>

                        <button type="submit" id="q-submit" class="btn btn-primary btn-block btn-lg">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4z"/></svg>
                            Submit Quote Request
                        </button>
                        <p class="form-disclaimer">We'll review your request and send a detailed quote within 24 hours. No obligation.</p>
                    </form>

                    <div id="form-success" style="display:none;">
                        <div class="success-card">
                            <div class="success-icon">✅</div>
                            <h2>Quote Request Submitted!</h2>
                            <p>We'll review your project details and send you a comprehensive quote within 24 hours.</p>
                            <p>Need faster answers? Call us at <a href={`tel:${site.company.phoneRaw}`}>{site.company.phone}</a></p>
                            <div style="display:flex; gap: 12px; justify-content: center; margin-top: 20px;">
                                <a href="/" class="btn btn-primary">Back to Home</a>
                                <a href="/quote/ballpark/" class="btn btn-secondary">Try Instant Quote</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-sidebar">
                    <div class="sidebar-card">
                        <h4>⚡ Need a Quick Estimate?</h4>
                        <p>Our ballpark calculator gives you a price range in 60 seconds.</p>
                        <a href="/quote/ballpark/" class="btn btn-primary btn-block">Try Instant Quote</a>
                    </div>
                    <div class="sidebar-card">
                        <h4>🤝 Our Promise</h4>
                        <ul class="promise-list">
                            <li>✓ Response within 24 hours</li>
                            <li>✓ Detailed written estimate</li>
                            <li>✓ No hidden fees</li>
                            <li>✓ Price-match guarantee</li>
                            <li>✓ 3-year workmanship warranty</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<!-- ✅ SECURITY FIX: Removed client-side Firebase SDK entirely.
     Now routes through /api/submit which has:
     - Server-side rate limiting (5 req/min/IP)
     - CSRF origin checking
     - Honeypot bot detection
     - Input sanitization & validation
     - Email notification via Firebase Trigger Email
-->
<script is:inline>
(function() {
    const $ = id => document.getElementById(id);

    $('quote-form').addEventListener('submit', async (e) => {
        e.preventDefault();

        // Honeypot check
        if ($('hp-website')?.value) return;

        const name = $('q-name').value.trim();
        const phone = $('q-phone').value.trim();
        const email = $('q-email').value.trim();
        const address = $('q-address').value.trim();
        const fenceType = $('q-type').value;

        if (!name || !phone || !email || !address || !fenceType) {
            alert('Please fill in all required fields.');
            return;
        }
        if (!/^[\d\s()+-]{7,20}$/.test(phone)) {
            alert('Please enter a valid phone number.');
            return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) {
            alert('Please enter a valid email address.');
            return;
        }

        const btn = $('q-submit');
        btn.disabled = true;
        btn.innerHTML = '⏳ Submitting...';

        try {
            // Build notes from all project details
            const details = [];
            if(window._getCustomFieldValues){window._getCustomFieldValues().forEach(function(v){details.push(v)});}
            const height = $('q-height').value;
            const length = $('q-length').value;
            const timeline = $('q-timeline').value;
            const gates = $('q-gates').value.trim();
            const doubleGates = $('q-double-gates').value.trim();
            const removal = $('q-removal').value.trim();
            const pool = $('q-pool').checked;
            const notes = $('q-notes').value.trim();
            const heard = $('q-heard').value;

            if (height) details.push('Height: ' + height);
            if (length) details.push('Length: ' + length);
            if (timeline) details.push('Timeline: ' + timeline);
            if (gates) details.push('Gates: ' + gates);
            if (doubleGates) details.push('Double Gates: ' + doubleGates);
            if (removal) details.push('Removal: ' + removal);
            if (pool) details.push('Pool area - code compliance');
            if (heard) details.push('Heard about us: ' + heard);
            if (notes) details.push('Notes: ' + notes);

            const res = await fetch('/api/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'contact',
                    name,
                    phone,
                    email,
                    address,
                    fenceType,
                    message: details.join('\n'),
                    website: $('hp-website')?.value || ''
                })
            });

            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                throw new Error(data.error || 'Submission failed');
            }

            // Backup: submit to Netlify Forms
            try {
                const netlifyForm = new FormData();
                netlifyForm.append('form-name', 'detailed-quote-leads');
                netlifyForm.append('name', name);
                netlifyForm.append('phone', phone);
                netlifyForm.append('email', email);
                netlifyForm.append('address', address);
                netlifyForm.append('fenceType', fenceType);
                netlifyForm.append('message', details.join('\n'));
                fetch('/__forms.html', { method: 'POST', body: netlifyForm }).catch(() => {});
            } catch(e) {}

            $('quote-form').style.display = 'none';
            $('form-success').style.display = 'block';
            $('form-success').scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch(err) {
            console.error('Form error:', err);
            alert('Submission failed. Please call us at (419) 902-8257.');
            btn.disabled = false;
            btn.innerHTML = 'Submit Quote Request';
        }
    });
})();
</script>

<!-- Custom Form Fields System -->
<script is:inline>
(function(){
  var FK='gfs_edit_formFields';
  function getF(){try{return JSON.parse(localStorage.getItem(FK)||'[]')}catch(e){return[]}}
  function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
  function render(){
    var box=document.getElementById('custom-fields-section');
    if(!box)return;
    var fields=getF();
    if(!fields.length){box.innerHTML='';return}
    var h='';
    fields.forEach(function(f,i){
      var req=f.required?' *':'',ra=f.required?' required':'';
      if(f.type==='text'){
        h+='<div class="form-group"><label for="cf-'+i+'">'+esc(f.label)+req+'</label><input type="text" id="cf-'+i+'"'+ra+' placeholder="'+esc(f.placeholder||'')+'" /></div>';
      }else if(f.type==='textarea'){
        h+='<div class="form-group"><label for="cf-'+i+'">'+esc(f.label)+req+'</label><textarea id="cf-'+i+'" rows="3"'+ra+' placeholder="'+esc(f.placeholder||'')+'"></textarea></div>';
      }else if(f.type==='checkbox'){
        h+='<div class="checkbox-row" style="margin-bottom:12px"><label class="checkbox-label"><input type="checkbox" id="cf-'+i+'" /> '+esc(f.label)+'</label></div>';
      }else if(f.type==='dropdown'){
        h+='<div class="form-group"><label for="cf-'+i+'">'+esc(f.label)+req+'</label><select id="cf-'+i+'"'+ra+'><option value="">Select...</option>';
        (f.options||[]).forEach(function(opt){h+='<option value="'+esc(opt)+'">'+esc(opt)+'</option>'});
        h+='</select></div>';
      }
    });
    box.innerHTML=h;
  }
  window._getCustomFieldValues=function(){
    var fields=getF(),vals=[];
    fields.forEach(function(f,i){
      var el=document.getElementById('cf-'+i);if(!el)return;
      var v=f.type==='checkbox'?(el.checked?'Yes':'No'):(el.value||'').trim();
      if(v&&v!=='No')vals.push(f.label+': '+v);
    });return vals;
  };
  // Load remote edits for form fields too
  fetch('/site-edits.json?_='+Date.now()).then(function(r){return r.ok?r.json():null}).then(function(d){
    if(d&&d[FK]&&!localStorage.getItem(FK))localStorage.setItem(FK,d[FK]);
    render();
  }).catch(function(){render()});
})();
</script>

<!-- Form Builder (Edit Mode only) -->
<script is:inline>
(function(){
  var FK='gfs_edit_formFields';
  function getF(){try{return JSON.parse(localStorage.getItem(FK)||'[]')}catch(e){return[]}}
  function saveF(f){localStorage.setItem(FK,JSON.stringify(f))}
  function esc(s){return String(s).replace(/"/g,'&quot;').replace(/</g,'&lt;')}
  var obs=new MutationObserver(function(){
    if(document.body.classList.contains('edit-mode-active'))inject();else remove();
  });
  obs.observe(document.body,{attributes:true,attributeFilter:['class']});
  function inject(){
    if(document.getElementById('fb-panel'))return;
    var sec=document.getElementById('custom-fields-section');if(!sec)return;
    var p=document.createElement('div');p.id='fb-panel';
    p.style.cssText='background:#fffbeb;border:2px dashed #d4af37;border-radius:12px;padding:24px;margin:20px 0;';
    p.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><h4 style="margin:0;color:#1e3a5f">Form Builder</h4><button id="fb-save" style="background:#059669;color:white;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-weight:600">Save & Publish</button></div><p style="font-size:13px;color:#6b7280;margin-bottom:16px">Add custom fields that appear on the form and submit to your Exec App.</p><div id="fb-list"></div><div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap"><select id="fb-type" style="padding:8px 12px;border:1px solid #d1d5db;border-radius:6px"><option value="text">Text Input</option><option value="textarea">Text Area</option><option value="checkbox">Checkbox</option><option value="dropdown">Dropdown</option></select><button id="fb-add" style="background:#1e3a5f;color:white;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-weight:500">+ Add Field</button></div>';
    sec.parentNode.insertBefore(p,sec);
    document.getElementById('fb-add').onclick=addField;
    document.getElementById('fb-save').onclick=function(){
      saveF(getF());
      var btn=this;btn.textContent='Publishing...';btn.disabled=true;
      // Push to GitHub via EditMode's exposed function
      if(window._gfsPushToGitHub){
        window._gfsPushToGitHub().then(function(ok){
          btn.textContent=ok?'Published!':'Saved locally';
          btn.disabled=false;
          setTimeout(function(){btn.textContent='Save & Publish'},2000);
          location.reload();
        });
      }else{
        btn.textContent='Saved locally';btn.disabled=false;
        setTimeout(function(){btn.textContent='Save & Publish'},2000);
        location.reload();
      }
    };
    renderList();
  }
  function remove(){var p=document.getElementById('fb-panel');if(p)p.remove()}
  function addField(){
    var type=document.getElementById('fb-type').value,fields=getF();
    fields.push({type:type,label:type==='checkbox'?'New Checkbox':'New Field',placeholder:'',required:false,options:type==='dropdown'?['Option 1','Option 2']:[]});
    saveF(fields);renderList();
    // re-render custom fields
    document.body.classList.remove('edit-mode-active');
    setTimeout(function(){document.body.classList.add('edit-mode-active')},50);
  }
  function renderList(){
    var list=document.getElementById('fb-list');if(!list)return;
    var fields=getF();
    if(!fields.length){list.innerHTML='<p style="color:#9ca3af;font-size:13px;font-style:italic">No custom fields yet.</p>';return}
    var icons={text:'T',textarea:'P',checkbox:'C',dropdown:'D'};
    list.innerHTML=fields.map(function(f,i){
      var h='<div style="background:white;border:1px solid #e2e8f0;border-radius:8px;padding:14px;margin-bottom:10px">';
      h+='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px"><span style="font-weight:600;font-size:13px">['+icons[f.type]+'] '+f.type.charAt(0).toUpperCase()+f.type.slice(1)+'</span>';
      h+='<div style="display:flex;gap:6px"><button onclick="window._fbMove('+i+',-1)" style="background:#f1f5f9;border:1px solid #e2e8f0;padding:4px 8px;border-radius:4px;cursor:pointer">Up</button><button onclick="window._fbMove('+i+',1)" style="background:#f1f5f9;border:1px solid #e2e8f0;padding:4px 8px;border-radius:4px;cursor:pointer">Dn</button><button onclick="window._fbDel('+i+')" style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;padding:4px 8px;border-radius:4px;cursor:pointer">X</button></div></div>';
      h+='<div style="display:flex;gap:8px;flex-wrap:wrap"><input type="text" value="'+esc(f.label)+'" onchange="window._fbSet('+i+',this.value)" placeholder="Label" style="flex:1;min-width:150px;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px" />';
      if(f.type!=='checkbox')h+='<input type="text" value="'+esc(f.placeholder||'')+'" onchange="window._fbSetP('+i+',this.value)" placeholder="Placeholder" style="flex:1;min-width:120px;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px" />';
      h+='<label style="display:flex;align-items:center;gap:4px;font-size:12px;white-space:nowrap"><input type="checkbox" '+(f.required?'checked':'')+' onchange="window._fbReq('+i+',this.checked)" /> Req</label></div>';
      if(f.type==='dropdown')h+='<div style="margin-top:8px"><label style="font-size:12px;color:#6b7280">Options (one per line):</label><textarea onchange="window._fbOpts('+i+',this.value)" style="width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;margin-top:4px" rows="3">'+(f.options||[]).join('\n')+'</textarea></div>';
      h+='</div>';return h;
    }).join('');
  }
  window._fbSet=function(i,v){var f=getF();if(f[i]){f[i].label=v;saveF(f);renderList()}};
  window._fbSetP=function(i,v){var f=getF();if(f[i]){f[i].placeholder=v;saveF(f)}};
  window._fbReq=function(i,v){var f=getF();if(f[i]){f[i].required=v;saveF(f)}};
  window._fbOpts=function(i,v){var f=getF();if(f[i]){f[i].options=v.split('\n').filter(function(x){return x.trim()});saveF(f)}};
  window._fbDel=function(i){if(!confirm('Delete this field?'))return;var f=getF();f.splice(i,1);saveF(f);renderList()};
  window._fbMove=function(i,d){var f=getF(),n=i+d;if(n<0||n>=f.length)return;var t=f[i];f[i]=f[n];f[n]=t;saveF(f);renderList()};
})();
</script>


<style>
    .hero-mini { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); padding: 120px 0 40px; color: white; }
    .hero-mini .breadcrumb { margin-bottom: 16px; font-size: 0.9rem; }
    .hero-mini .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
    .hero-mini .breadcrumb span { color: white; }
    .hero-mini h1 { font-size: clamp(2rem, 4vw, 2.5rem); margin-bottom: 8px; }
    .hero-mini .subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; }
    .form-section { padding: 60px 0; background: var(--bg-light); }
    .form-grid { display: grid; grid-template-columns: 1fr 320px; gap: 40px; align-items: start; }
    @media (max-width: 900px) { .form-grid { grid-template-columns: 1fr; } .form-sidebar { order: -1; } }
    .form-card { background: white; border-radius: var(--radius-lg); padding: 32px; margin-bottom: 24px; box-shadow: var(--shadow-sm); }
    .form-card h3 { margin: 0 0 24px; font-size: 1.2rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; margin-bottom: 6px; font-weight: 500; font-size: 0.95rem; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 1rem; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--primary); outline: none; }
    .checkbox-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 8px; }
    .checkbox-label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.95rem; }
    .checkbox-label input { width: 18px; height: 18px; }
    .btn-block { width: 100%; justify-content: center; }
    .btn-lg { padding: 14px 24px; font-size: 1.05rem; }
    .form-disclaimer { text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 12px; }
    .success-card { text-align: center; background: white; border-radius: var(--radius-lg); padding: 48px 32px; box-shadow: var(--shadow-md); }
    .success-icon { font-size: 4rem; margin-bottom: 16px; }
