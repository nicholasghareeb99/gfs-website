---
/**
 * EditMode.astro — Squarespace-like visual editor for GFS website
 * Features: Inline text editing, drag-and-drop, image replacement,
 *           nav/topbar editing, per-element color/font, page toggle,
 *           localStorage persistence
 */
---

<!-- Edit Toolbar -->
<div id="edit-toolbar" style="display:none;">
  <div class="et-bar">
    <div class="et-left">
      <div class="et-logo">✏️ GFS Editor</div>
      <span class="et-page" id="et-page-name"></span>
    </div>
    <div class="et-center">
      <button id="et-toggle" class="et-btn et-btn-edit" title="Toggle editing">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        <span>Edit Page</span>
      </button>
      <button id="et-nav-btn" class="et-btn" title="Edit navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <span>Nav</span>
      </button>
      <button id="et-pages-btn" class="et-btn" title="Manage pages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>Pages</span>
      </button>
      <button id="et-colors-btn" class="et-btn" title="Brand colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10c0 2-1 3-3 3h-1.9c-.8 0-1.1.9-.5 1.4.5.4.8 1 .8 1.6 0 1.7-1.3 3-3 3z"/></svg>
        <span>Colors</span>
      </button>
      <button id="et-seo-btn" class="et-btn" title="SEO settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>SEO</span>
      </button>
    </div>
    <div class="et-right">
      <span id="et-changes" class="et-changes" style="display:none;">0 changes</span>
      <button id="et-save" class="et-btn et-btn-save" style="display:none;">💾 Save</button>
      <button id="et-discard" class="et-btn" style="display:none;">Discard</button>
      <button id="et-logout" class="et-btn et-btn-ghost">↪ Exit</button>
    </div>
  </div>
</div>
<!-- Element Style Popover -->
<div id="et-style-popover" class="et-popover" style="display:none;">
  <div class="et-pop-row"><label>Text Color</label><input type="color" id="et-pop-color" /></div>
  <div class="et-pop-row"><label>Background</label><input type="color" id="et-pop-bg" /></div>
  <div class="et-pop-row"><label>Font Size</label><input type="range" id="et-pop-size" min="10" max="72" value="16" /><span id="et-pop-size-val">16px</span></div>
  <div class="et-pop-row"><label>Weight</label><select id="et-pop-weight"><option value="400">Normal</option><option value="500">Medium</option><option value="600">Semi-Bold</option><option value="700">Bold</option><option value="800">Extra Bold</option></select></div>
  <div class="et-pop-row"><label>Align</label><div class="et-pop-align"><button data-align="left">◀</button><button data-align="center">◆</button><button data-align="right">▶</button></div></div>
  <div class="et-pop-actions"><button id="et-pop-move" class="et-btn-small">↕ Move</button><button id="et-pop-done" class="et-btn-small et-btn-save">Done</button></div>
</div>

<!-- Login Modal -->
<div id="et-login-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content">
    <h3>🔐 Admin Login</h3>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:14px;color:#6b7280;">Username</label><input type="text" id="et-login-email" placeholder="admin" autocomplete="username" /></div>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:14px;color:#6b7280;">Password</label><input type="password" id="et-login-password" placeholder="••••••••" autocomplete="current-password" /></div>
    <div id="et-login-error" style="color:#ef4444;font-size:13px;margin-bottom:12px;display:none;"></div>
    <div class="et-modal-actions"><button id="et-login-cancel" class="et-btn">Cancel</button><button id="et-login-submit" class="et-btn et-btn-save">Login</button></div>
  </div>
</div>

<!-- Image Upload Modal -->
<div id="et-image-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content">
    <h3>Replace Image</h3>
    <div class="et-upload-zone" id="et-upload-zone"><p>📷 Drag & drop or click to browse</p><input type="file" id="et-file-input" accept="image/*" style="display:none;" /></div>
    <div id="et-upload-preview" style="display:none;margin:12px 0;"><img id="et-preview-img" src="" alt="Preview" style="max-width:100%;max-height:200px;border-radius:8px;" /></div>
    <div style="margin:12px 0;"><label style="font-size:13px;color:#6b7280;">Or enter image URL:</label><input type="url" id="et-image-url" placeholder="https://..." /></div>
    <div class="et-modal-actions"><button id="et-image-cancel" class="et-btn">Cancel</button><button id="et-image-apply" class="et-btn et-btn-save">Apply</button></div>
  </div>
</div>

<!-- Page Manager Modal -->
<div id="et-pages-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:500px;">
    <h3>📄 Page Manager</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Toggle pages on/off in the navigation.</p>
    <div id="et-pages-list"></div>
    <div class="et-modal-actions" style="margin-top:16px;"><button id="et-pages-close" class="et-btn">Close</button><button id="et-pages-save" class="et-btn et-btn-save">Save</button></div>
  </div>
</div>

<!-- Color Editor Modal -->
<div id="et-colors-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:480px;">
    <h3>🎨 Brand Colors</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Changes preview live.</p>
    <div id="et-colors-list"></div>
    <div class="et-modal-actions" style="margin-top:16px;"><button id="et-colors-close" class="et-btn">Close</button><button id="et-colors-save" class="et-btn et-btn-save">Save Colors</button></div>
  </div>
</div>

<!-- Nav Editor Modal -->
<div id="et-nav-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:600px;">
    <h3>🧭 Navigation Editor</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Edit top bar text and nav links.</p>
    <div id="et-nav-topbar" style="margin-bottom:20px;"><h4 style="font-size:14px;margin-bottom:8px;color:#1e3a5f;">Top Bar Items</h4><div id="et-topbar-items"></div></div>
    <div id="et-nav-links" style="margin-bottom:20px;"><h4 style="font-size:14px;margin-bottom:8px;color:#1e3a5f;">Main Navigation</h4><div id="et-nav-items"></div></div>
    <div class="et-modal-actions"><button id="et-nav-close" class="et-btn">Close</button><button id="et-nav-save" class="et-btn et-btn-save">Save Nav</button></div>
  </div>
</div>

<!-- SEO Editor Modal -->
<div id="et-seo-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:550px;">
    <h3>🔍 Page SEO</h3>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:#374151;">Page Title</label><input type="text" id="et-seo-title" /><span id="et-seo-title-count" style="font-size:11px;color:#9ca3af;"></span></div>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:#374151;">Meta Description</label><textarea id="et-seo-desc" rows="3" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea><span id="et-seo-desc-count" style="font-size:11px;color:#9ca3af;"></span></div>
    <div class="et-modal-actions"><button id="et-seo-close" class="et-btn">Close</button><button id="et-seo-save" class="et-btn et-btn-save">Save SEO</button></div>
  </div>
</div>
