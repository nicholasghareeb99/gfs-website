  // === IMAGE EDITING ===
  let curImgEl=null,curImgKey=null,curIsBg=false;
  function openImageModal(el,key,isBg){curImgEl=el;curImgKey=key;curIsBg=!!isBg;const m=document.getElementById('et-image-modal');m.style.display='flex';document.getElementById('et-image-url').value='';document.getElementById('et-upload-preview').style.display='none';document.getElementById('et-file-input').value='';
