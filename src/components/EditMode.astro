---
/**
 * EditMode.astro — Squarespace-like visual editor for GFS website
 * Features: Inline text editing, drag-and-drop, image replacement,
 *           nav/topbar editing, per-element color/font, page toggle,
 *           localStorage persistence
 */
---

<!-- Edit Toolbar -->
<div id="edit-toolbar" style="display:none;">
  <div class="et-bar">
    <div class="et-left">
      <div class="et-logo">✏️ GFS Editor</div>
      <span class="et-page" id="et-page-name"></span>
    </div>
    <div class="et-center">
      <button id="et-toggle" class="et-btn et-btn-edit" title="Toggle editing">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        <span>Edit Page</span>
      </button>
      <button id="et-nav-btn" class="et-btn" title="Edit navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <span>Nav</span>
      </button>
      <button id="et-logo-btn" class="et-btn" title="Edit logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="12" y="16" text-anchor="middle" font-size="10" fill="currentColor" stroke="none" font-weight="bold">GF</text></svg>
        <span>Logo</span>
      </button>
      <button id="et-pages-btn" class="et-btn" title="Manage pages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>Pages</span>
      </button>
      <button id="et-colors-btn" class="et-btn" title="Brand colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10c0 2-1 3-3 3h-1.9c-.8 0-1.1.9-.5 1.4.5.4.8 1 .8 1.6 0 1.7-1.3 3-3 3z"/></svg>
        <span>Colors</span>
      </button>
      <button id="et-admin-btn" class="et-btn" title="Admin Panel">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
<span>Admin</span>
</button>
<button id="et-seo-btn" class="et-btn" title="SEO settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>SEO</span>
      </button>
    </div>
    <div class="et-right">
      <span id="et-changes" class="et-changes" style="display:none;">0 changes</span>
      <button id="et-save" class="et-btn et-btn-save" style="display:none;">💾 Save</button>
      <button id="et-discard" class="et-btn" style="display:none;">Discard</button>
      <button id="et-logout" class="et-btn et-btn-ghost">↪ Exit</button>
    </div>
  </div>
</div>

<!-- Element Style Popover -->
<div id="et-style-popover" class="et-popover" style="display:none;">
  <div class="et-pop-row"><label>Text Color</label><input type="color" id="et-pop-color" /></div>
  <div class="et-pop-row"><label>Background</label><input type="color" id="et-pop-bg" /></div>
  <div class="et-pop-row"><label>Font Size</label><input type="range" id="et-pop-size" min="10" max="72" value="16" /><span id="et-pop-size-val">16px</span></div>
  <div class="et-pop-row"><label>Weight</label><select id="et-pop-weight"><option value="400">Normal</option><option value="500">Medium</option><option value="600">Semi-Bold</option><option value="700">Bold</option><option value="800">Extra Bold</option></select></div>
  <div class="et-pop-row"><label>Align</label><div class="et-pop-align"><button data-align="left">◀</button><button data-align="center">◆</button><button data-align="right">▶</button></div></div>
  <div class="et-pop-row"><label>Width</label><input type="range" id="et-pop-width" min="50" max="1200" value="100" /><span id="et-pop-width-val">auto</span></div>
<div class="et-pop-row"><label>Max Width</label><input type="range" id="et-pop-maxw" min="100" max="1200" value="1200" /><span id="et-pop-maxw-val">none</span></div>
<div class="et-pop-row"><label>Padding</label><input type="range" id="et-pop-pad" min="0" max="80" value="0" /><span id="et-pop-pad-val">0px</span></div>
<div class="et-pop-row"><label>Margin</label><input type="range" id="et-pop-margin" min="0" max="80" value="0" /><span id="et-pop-margin-val">0px</span></div>
<div class="et-pop-row"><label>Border R.</label><input type="range" id="et-pop-radius" min="0" max="50" value="0" /><span id="et-pop-radius-val">0px</span></div>
<div class="et-pop-actions"><button id="et-pop-move" class="et-btn-small">↕ Move</button><button id="et-pop-done" class="et-btn-small et-btn-save">Done</button></div>
</div>

<!-- Login Modal -->
<div id="et-login-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content">
    <h3>🔐 Admin Login</h3>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:14px;color:#6b7280;">Username</label><input type="text" id="et-login-email" placeholder="admin" autocomplete="username" /></div>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:14px;color:#6b7280;">Password</label><input type="password" id="et-login-password" placeholder="••••••••" autocomplete="current-password" /></div>
    <div id="et-login-error" style="color:#ef4444;font-size:13px;margin-bottom:12px;display:none;"></div>
    <div class="et-modal-actions"><button id="et-login-cancel" class="et-btn">Cancel</button><button id="et-login-submit" class="et-btn et-btn-save">Login</button></div>
  </div>
</div>

<!-- Image Upload Modal -->
<div id="et-image-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content">
    <h3 id="et-image-modal-title">Replace Image</h3>
    <div class="et-upload-zone" id="et-upload-zone"><p>📷 Drag & drop or click to browse</p><input type="file" id="et-file-input" accept="image/*" style="display:none;" /></div>
    <div id="et-upload-preview" style="display:none;margin:12px 0;"><img id="et-preview-img" src="" alt="Preview" style="max-width:100%;max-height:200px;border-radius:8px;" /></div>
    <div style="margin:12px 0;"><label style="font-size:13px;color:#6b7280;">Or enter image URL:</label><input type="url" id="et-image-url" placeholder="https://..." /></div>
    <div id="et-alt-section" style="margin:12px 0;">
      <label style="font-size:13px;color:#6b7280;">Image Description (alt text):</label>
      <input type="text" id="et-image-alt" placeholder="Describe this image..." style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" />
    </div>
    <div id="et-caption-section" style="margin:12px 0;display:none;">
      <label style="font-size:13px;color:#6b7280;">Caption (shown below image):</label>
      <input type="text" id="et-image-caption" placeholder="Optional caption text..." style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" />
    </div>
    <div class="et-modal-actions"><button id="et-image-cancel" class="et-btn">Cancel</button><button id="et-image-apply" class="et-btn et-btn-save">Apply</button></div>
  </div>
</div>

<!-- Logo Editor Modal -->
<div id="et-logo-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:480px;">
    <h3>✏️ Edit Logo</h3>
    <div style="margin-bottom:16px;">
      <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;">Logo Style</label>
      <div style="display:flex;gap:8px;">
        <button id="et-logo-type-text" class="et-btn et-btn-save" style="flex:1;">Text Logo</button>
        <button id="et-logo-type-image" class="et-btn" style="flex:1;">Image Logo</button>
      </div>
    </div>
    <div id="et-logo-text-fields">
      <div style="margin-bottom:12px;">
        <label style="font-size:13px;color:#6b7280;">Logo Icon Text (1-3 chars):</label>
        <input type="text" id="et-logo-icon" maxlength="3" placeholder="GF" style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" />
      </div>
      <div style="margin-bottom:12px;">
        <label style="font-size:13px;color:#6b7280;">Company Name (top line):</label>
        <input type="text" id="et-logo-name" placeholder="GHAREEB" style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" />
      </div>
      <div style="margin-bottom:12px;">
        <label style="font-size:13px;color:#6b7280;">Tagline (bottom line):</label>
        <input type="text" id="et-logo-tagline" placeholder="FENCING" style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" />
      </div>
    </div>
    <div id="et-logo-image-fields" style="display:none;">
      <div class="et-upload-zone" id="et-logo-upload-zone" style="margin-bottom:12px;"><p>📷 Upload logo image</p><input type="file" id="et-logo-file-input" accept="image/*" style="display:none;" /></div>
      <div id="et-logo-preview" style="display:none;margin:12px 0;text-align:center;"><img id="et-logo-preview-img" src="" alt="Logo Preview" style="max-height:80px;border-radius:4px;" /></div>
      <div style="margin:8px 0;"><label style="font-size:13px;color:#6b7280;">Or logo URL:</label><input type="url" id="et-logo-image-url" placeholder="https://..." style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;margin-top:4px;" /></div>
      <div style="margin:8px 0;">
        <label style="font-size:13px;color:#6b7280;">Max Height (px):</label>
        <input type="range" id="et-logo-height" min="30" max="120" value="50" style="width:100%;" />
        <span id="et-logo-height-val" style="font-size:12px;color:#9ca3af;">50px</span>
      </div>
    </div>
    <div class="et-modal-actions"><button id="et-logo-cancel" class="et-btn">Cancel</button><button id="et-logo-apply" class="et-btn et-btn-save">Apply</button></div>
  </div>
</div>

<!-- Page Manager Modal -->
<div id="et-pages-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:500px;">
    <h3>📄 Page Manager</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Toggle pages on/off in the navigation.</p>
    <div id="et-pages-list"></div>
    <div class="et-modal-actions" style="margin-top:16px;"><button id="et-pages-close" class="et-btn">Close</button><button id="et-pages-save" class="et-btn et-btn-save">Save</button></div>
  </div>
</div>

<!-- Color Editor Modal -->
<div id="et-colors-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:480px;">
    <h3>🎨 Brand Colors</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Changes preview live.</p>
    <div id="et-colors-list"></div>
    <div class="et-modal-actions" style="margin-top:16px;"><button id="et-colors-close" class="et-btn">Close</button><button id="et-colors-save" class="et-btn et-btn-save">Save Colors</button></div>
  </div>
</div>

<!-- Nav Editor Modal -->
<div id="et-nav-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:600px;">
    <h3>🧭 Navigation Editor</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:16px;">Edit top bar text and nav links.</p>
    <div id="et-nav-topbar" style="margin-bottom:20px;"><h4 style="font-size:14px;margin-bottom:8px;color:#1e3a5f;">Top Bar Items</h4><div id="et-topbar-items"></div></div>
    <div id="et-nav-links" style="margin-bottom:20px;"><h4 style="font-size:14px;margin-bottom:8px;color:#1e3a5f;">Main Navigation</h4><div id="et-nav-items"></div></div>
    <div class="et-modal-actions"><button id="et-nav-close" class="et-btn">Close</button><button id="et-nav-save" class="et-btn et-btn-save">Save Nav</button></div>
  </div>
</div>

<!-- SEO Editor Modal -->
<div id="et-seo-modal" class="et-modal" style="display:none;">
  <div class="et-modal-content" style="max-width:550px;">
    <h3>🔍 Page SEO</h3>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:#374151;">Page Title</label><input type="text" id="et-seo-title" /><span id="et-seo-title-count" style="font-size:11px;color:#9ca3af;"></span></div>
    <div style="margin-bottom:16px;"><label style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:#374151;">Meta Description</label><textarea id="et-seo-desc" rows="3" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea><span id="et-seo-desc-count" style="font-size:11px;color:#9ca3af;"></span></div>
    <div class="et-modal-actions"><button id="et-seo-close" class="et-btn">Close</button><button id="et-seo-save" class="et-btn et-btn-save">Save SEO</button></div>
  </div>
</div>

<!-- Admin Panel Modal -->
<div id="et-admin-modal" class="et-modal" style="display:none;">
<div class="et-modal-content" style="max-width:900px;max-height:90vh;">
<div class="et-admin-header">
<h3>⚙️ Admin Panel</h3>
<div class="et-admin-tabs">
<button class="et-admin-tab active" data-tab="seo">🔍 SEO</button>
<button class="et-admin-tab" data-tab="analytics">📊 Analytics</button>
<button class="et-admin-tab" data-tab="settings">⚙️ Settings</button>
</div>
</div>
<div class="et-admin-body">
<!-- SEO Tab -->
<div class="et-admin-pane active" id="et-admin-seo">
<div class="et-seo-section">
<h4>Page Meta</h4>
<div class="et-field"><label>Page Title</label><input type="text" id="et-adm-title" /><span class="et-field-hint" id="et-adm-title-ct"></span></div>
<div class="et-field"><label>Meta Description</label><textarea id="et-adm-desc" rows="3"></textarea><span class="et-field-hint" id="et-adm-desc-ct"></span></div>
<div class="et-field"><label>Keywords (comma separated)</label><input type="text" id="et-adm-keywords" placeholder="cedar fence toledo, fence installation ohio" /></div>
<div class="et-field"><label>Canonical URL</label><input type="url" id="et-adm-canonical" placeholder="https://ghareebfencing.com/fences/cedar/" /></div>
</div>
<div class="et-seo-section">
<h4>Open Graph / Social</h4>
<div class="et-field"><label>OG Title</label><input type="text" id="et-adm-og-title" placeholder="Override page title for social" /></div>
<div class="et-field"><label>OG Description</label><textarea id="et-adm-og-desc" rows="2" placeholder="Override description for social"></textarea></div>
<div class="et-field"><label>OG Image URL</label><input type="url" id="et-adm-og-image" placeholder="https://..." /></div>
<div class="et-field"><label>OG Type</label><select id="et-adm-og-type"><option value="website">Website</option><option value="article">Article</option><option value="product">Product</option></select></div>
</div>
<div class="et-seo-section">
<h4>Advanced</h4>
<div class="et-field"><label>Robots</label><select id="et-adm-robots"><option value="index,follow">Index, Follow</option><option value="noindex,follow">No Index, Follow</option><option value="index,nofollow">Index, No Follow</option><option value="noindex,nofollow">No Index, No Follow</option></select></div>
<div class="et-field"><label>Schema Type</label><select id="et-adm-schema"><option value="LocalBusiness">Local Business</option><option value="Service">Service</option><option value="Product">Product</option><option value="FAQPage">FAQ Page</option></select></div>
<div class="et-seo-preview">
<h4>🔍 Google Preview</h4>
<div class="et-google-preview">
<div class="et-gp-title" id="et-gp-title">Page Title</div>
<div class="et-gp-url" id="et-gp-url">ghareebfencing.com</div>
<div class="et-gp-desc" id="et-gp-desc">Meta description preview...</div>
</div>
</div>
</div>
</div>
<!-- Analytics Tab -->
<div class="et-admin-pane" id="et-admin-analytics">
<div class="et-analytics-grid">
<div class="et-stat-card"><div class="et-stat-num" id="et-stat-views">0</div><div class="et-stat-lbl">Page Views</div><div class="et-stat-sub">Last 30 days</div></div>
<div class="et-stat-card"><div class="et-stat-num" id="et-stat-visitors">0</div><div class="et-stat-lbl">Unique Visitors</div><div class="et-stat-sub">Last 30 days</div></div>
<div class="et-stat-card"><div class="et-stat-num" id="et-stat-bounce">0%</div><div class="et-stat-lbl">Bounce Rate</div><div class="et-stat-sub">Estimated</div></div>
<div class="et-stat-card"><div class="et-stat-num" id="et-stat-avg">0s</div><div class="et-stat-lbl">Avg Time</div><div class="et-stat-sub">On page</div></div>
</div>
<div class="et-analytics-section">
<h4>📈 Page Views (Last 7 Days)</h4>
<div class="et-chart" id="et-chart-views"></div>
</div>
<div class="et-analytics-section">
<h4>📍 Top Pages</h4>
<div id="et-top-pages" class="et-top-list"></div>
</div>
<div class="et-analytics-section">
<h4>🌍 Visitor Locations</h4>
<div id="et-visitor-locations" class="et-top-list"></div>
</div>
<div class="et-analytics-section">
<h4>📱 Device Breakdown</h4>
<div id="et-device-stats" class="et-device-grid"></div>
</div>
<div class="et-analytics-section">
<h4>🔗 Top Referrers</h4>
<div id="et-referrers" class="et-top-list"></div>
</div>
<p style="font-size:12px;color:#9ca3af;text-align:center;margin-top:16px;">Analytics data is tracked locally. For full analytics, connect Google Analytics 4.</p>
</div>
<!-- Settings Tab -->
<div class="et-admin-pane" id="et-admin-settings">
<div class="et-settings-section">
<h4>Site Settings</h4>
<div class="et-field"><label>Company Name</label><input type="text" id="et-set-company" value="Ghareeb Fencing Solutions" /></div>
<div class="et-field"><label>Phone Number</label><input type="tel" id="et-set-phone" value="(419) 902-8257" /></div>
<div class="et-field"><label>Email</label><input type="email" id="et-set-email" value="ng.ghareebfencingsolutions@outlook.com" /></div>
<div class="et-field"><label>Service Area</label><input type="text" id="et-set-area" value="Toledo, OH Area" /></div>
</div>
<div class="et-settings-section">
<h4>Integrations</h4>
<div class="et-field"><label>Google Analytics ID</label><input type="text" id="et-set-ga" placeholder="G-XXXXXXXXXX" /><span class="et-field-hint">Enter your GA4 Measurement ID</span></div>
<div class="et-field"><label>Google Tag Manager</label><input type="text" id="et-set-gtm" placeholder="GTM-XXXXXXX" /></div>
<div class="et-field"><label>Facebook Pixel</label><input type="text" id="et-set-fbpixel" placeholder="XXXXXXXXXXXXXXX" /></div>
</div>
<div class="et-settings-section">
<h4>Advanced</h4>
<div class="et-field"><label>Custom Head Code</label><textarea id="et-set-headcode" rows="4" placeholder="<!-- Custom scripts, meta tags, etc. -->"></textarea></div>
<button id="et-clear-cache" class="et-btn" style="margin-top:8px;color:#ef4444;border-color:#ef4444;">🗑️ Clear All Edit Cache</button>
<button id="et-export-data" class="et-btn" style="margin-top:8px;color:#059669;border-color:#059669;">📤 Export All Data</button>
</div>
</div>
</div>
<div class="et-modal-actions"><button id="et-admin-close" class="et-btn">Close</button><button id="et-admin-save" class="et-btn et-btn-save">Save All</button></div>
</div>
</div>

<style is:global>
  #edit-toolbar{position:fixed;top:0;left:0;right:0;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
  .et-bar{display:flex;align-items:center;justify-content:space-between;background:#1a1a2e;color:#fff;padding:8px 16px;box-shadow:0 2px 12px rgba(0,0,0,.3);gap:8px;flex-wrap:wrap}
  .et-left,.et-center,.et-right{display:flex;align-items:center;gap:8px}
  .et-logo{font-weight:700;font-size:14px}.et-page{font-size:12px;color:rgba(255,255,255,.6)}
