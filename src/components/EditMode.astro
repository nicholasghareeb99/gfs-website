  function loadAnalytics(){
    const ak='gfs_analytics_';
    const views=JSON.parse(localStorage.getItem(ak+'views')||'{}');
    const visitors=JSON.parse(localStorage.getItem(ak+'visitors')||'{}');
    const devs=JSON.parse(localStorage.getItem(ak+'devices')||'{}');
    const refs=JSON.parse(localStorage.getItem(ak+'referrers')||'{}');
    const locs=JSON.parse(localStorage.getItem(ak+'locations')||'{}');
    const times=JSON.parse(localStorage.getItem(ak+'times')||'{}');
    // Calculate totals for last 30 days
    const now=new Date();let totalViews=0,totalVisitors=0;
    for(let i=0;i<30;i++){
      const d=new Date(now);d.setDate(d.getDate()-i);
      const key=d.toISOString().split('T')[0];
      if(views[key])Object.values(views[key]).forEach(v=>totalViews+=v);
      if(visitors[key])totalVisitors+=visitors[key].length;
    }
    document.getElementById('et-stat-views').textContent=totalViews.toLocaleString();
    document.getElementById('et-stat-visitors').textContent=totalVisitors.toLocaleString();
    // Bounce rate estimate
    const totalDevices=Object.values(devs).reduce((a,b)=>a+b,0);
    const bounceEst=totalViews>0?Math.max(20,Math.min(70,Math.round(100-((totalVisitors/Math.max(totalViews,1))*100))))+'%':'N/A';
    document.getElementById('et-stat-bounce').textContent=bounceEst;
    // Avg time
    let totalTime=0,totalCount=0;
    Object.values(times).forEach(t=>{totalTime+=t.total;totalCount+=t.count});
    const avgTime=totalCount>0?Math.round(totalTime/totalCount):0;
    document.getElementById('et-stat-avg').textContent=avgTime>60?Math.round(avgTime/60)+'m':avgTime+'s';
    // Chart - last 7 days
    const chartEl=document.getElementById('et-chart-views');
    chartEl.innerHTML='';
    let maxDayViews=1;
    const days=[];
    for(let i=6;i>=0;i--){
      const d=new Date(now);d.setDate(d.getDate()-i);
      const key=d.toISOString().split('T')[0];
      let dayTotal=0;
      if(views[key])Object.values(views[key]).forEach(v=>dayTotal+=v);
      days.push({key,total:dayTotal,label:['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()]});
      if(dayTotal>maxDayViews)maxDayViews=dayTotal;
    }
    days.forEach(day=>{
      const pct=Math.max(4,(day.total/maxDayViews)*100);
      chartEl.innerHTML+=`<div class="et-chart-bar" style="height:${pct}%"><span class="et-chart-tip">${day.label}: ${day.total}</span></div>`;
    });
    // Top pages
    const pageStats={};
    Object.values(views).forEach(dayData=>{Object.entries(dayData).forEach(([pg,ct])=>{pageStats[pg]=(pageStats[pg]||0)+ct})});
    const topPages=Object.entries(pageStats).sort((a,b)=>b[1]-a[1]).slice(0,8);
    const maxPV=topPages[0]?topPages[0][1]:1;
    document.getElementById('et-top-pages').innerHTML=topPages.length?topPages.map(([pg,ct])=>`<div class="et-top-item"><span class="et-top-item-name">${pg||'/'}</span><div class="et-top-item-bar"><div class="et-top-item-bar-fill" style="width:${(ct/maxPV)*100}%"></div></div><span class="et-top-item-val">${ct}</span></div>`).join(''):'<div class="et-top-item"><span style="color:#9ca3af">No data yet</span></div>';
    // Locations
    const topLocs=Object.entries(locs).sort((a,b)=>b[1]-a[1]).slice(0,6);
    const maxLoc=topLocs[0]?topLocs[0][1]:1;
    document.getElementById('et-visitor-locations').innerHTML=topLocs.length?topLocs.map(([loc,ct])=>{
      const name=loc.split('/').pop().replace(/_/g,' ');
      return `<div class="et-top-item"><span class="et-top-item-name">\ud83d\udccd ${name}</span><div class="et-top-item-bar"><div class="et-top-item-bar-fill" style="width:${(ct/maxLoc)*100}%"></div></div><span class="et-top-item-val">${ct}</span></div>`;
    }).join(''):'<div class="et-top-item"><span style="color:#9ca3af">No data yet</span></div>';
    // Devices
    const totalDev=Object.values(devs).reduce((a,b)=>a+b,0)||1;
    const devIcons={desktop:'\ud83d\udcbb',mobile:'\ud83d\udcf1',tablet:'\ud83d\udcf1'};
    document.getElementById('et-device-stats').innerHTML=['desktop','mobile','tablet'].map(d=>{
      const ct=devs[d]||0;const pct=Math.round((ct/totalDev)*100);
      return `<div class="et-device-card"><div class="et-device-icon">${devIcons[d]}</div><div class="et-device-pct">${pct}%</div><div class="et-device-name">${d}</div></div>`;
    }).join('');
    // Referrers
    const topRefs=Object.entries(refs).sort((a,b)=>b[1]-a[1]).slice(0,6);
    const maxRef=topRefs[0]?topRefs[0][1]:1;
    document.getElementById('et-referrers').innerHTML=topRefs.length?topRefs.map(([ref,ct])=>`<div class="et-top-item"><span class="et-top-item-name">\ud83d\udd17 ${ref}</span><div class="et-top-item-bar"><div class="et-top-item-bar-fill" style="width:${(ct/maxRef)*100}%"></div></div><span class="et-top-item-val">${ct}</span></div>`).join(''):'<div class="et-top-item"><span style="color:#9ca3af">No referrer data yet</span></div>';
  }
