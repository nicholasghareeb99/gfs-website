  function updateChangesCount(){let c=0;changes.forEach(f=>{c+=Object.keys(f).length});const el=document.getElementById('et-changes'),sb=document.getElementById('et-save'),db=document.getElementById('et-discard');if(c>0){el.style.display='inline';el.textContent=c+' change'+(c!==1?'s':'');sb.style.display='inline-flex';db.style.display='inline-flex'}else{el.style.display='none';sb.style.display='none';db.style.display='none'}}

  // === SAVE / DISCARD ===
  function saveChanges(){if(changes.size===0)return;const sb=document.getElementById('et-save');sb.innerHTML='⏳ Saving...';sb.disabled=true;try{changes.forEach((fields,pk)=>{const ex=JSON.parse(localStorage.getItem(SP+'content_'+pk)||'{}');Object.assign(ex,fields);localStorage.setItem(SP+'content_'+pk,JSON.stringify(ex))});document.querySelectorAll('[data-et-editable]').forEach(el=>originalContent.set(el,el.innerHTML));changes.clear();updateChangesCount();sb.innerHTML='⏳ Publishing...';pushToGitHub().then(ok=>{if(ok){sb.innerHTML='✅ Published!';showToast('✅ Changes saved & published!')}else{sb.innerHTML='⚠️ Saved locally';showToast('⚠️ Saved locally — GitHub push failed. Check token.')}setTimeout(()=>{sb.innerHTML='💾 Save';sb.disabled=false},2500)})}catch(e){sb.innerHTML='❌ Error';sb.disabled=false;showToast('❌ '+e.message)}}

  // === GITHUB PUSH ===
  async function pushToGitHub(){
    try{
      // 1. Collect all gfs_edit_ data
      const data={};
      for(let i=0;i<localStorage.length;i++){
        const k=localStorage.key(i);
        if(k&&k.startsWith('gfs_edit_'))data[k]=localStorage.getItem(k);
      }
      data._updatedAt=new Date().toISOString();
      data._updatedBy='edit-mode';
      const json=JSON.stringify(data,null,2);
      const b64=btoa(unescape(encodeURIComponent(json)));

      // 2. Get GitHub token from server
      const tokenRes=await fetch('/api/editor-token',{headers:{'Authorization':'Bearer '+document.cookie}});
      if(!tokenRes.ok){console.error('Editor token fetch failed:',tokenRes.status);return false}
      const{token}=await tokenRes.json();
      if(!token){console.error('No GitHub token returned');return false}

      // 3. Get current file SHA (if exists)
      const owner='nicholasghareeb99',repo='gfs-website',path='public/site-edits.json';
      let sha=null;
      try{
        const getRes=await fetch('https://api.github.com/repos/'+owner+'/'+repo+'/contents/'+path+'?ref=main',{headers:{'Authorization':'token '+token,'Accept':'application/vnd.github.v3+json'}});
        if(getRes.ok){const f=await getRes.json();sha=f.sha}
      }catch(e){}

      // 4. Commit the file
      const body={message:'Update site edits [EditMode]',content:b64,branch:'main'};
      if(sha)body.sha=sha;
      const putRes=await fetch('https://api.github.com/repos/'+owner+'/'+repo+'/contents/'+path,{
        method:'PUT',
        headers:{'Authorization':'token '+token,'Accept':'application/vnd.github.v3+json','Content-Type':'application/json'},
        body:JSON.stringify(body)
      });
      if(putRes.ok){console.log('[EditMode] Published to GitHub');return true}
      else{const err=await putRes.text();console.error('[EditMode] GitHub push failed:',err);return false}
    }catch(e){console.error('[EditMode] pushToGitHub error:',e);return false}
  }

  // Expose for form builder and other scripts
