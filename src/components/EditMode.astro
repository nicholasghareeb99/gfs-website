<script is:inline>
(function(){
  'use strict';
  // === ANALYTICS TRACKER ===
  (function trackVisit(){
    try{
      const ak='gfs_analytics_';
      const today=new Date().toISOString().split('T')[0];
      const pg=window.location.pathname;
      // Track pageview
      const views=JSON.parse(localStorage.getItem(ak+'views')||'{}');
      if(!views[today])views[today]={};
      views[today][pg]=(views[today][pg]||0)+1;
      localStorage.setItem(ak+'views',JSON.stringify(views));
      // Track unique visitor
      let vid=localStorage.getItem(ak+'vid');
      if(!vid){vid='v_'+Math.random().toString(36).substr(2,9);localStorage.setItem(ak+'vid',vid)}
      const visitors=JSON.parse(localStorage.getItem(ak+'visitors')||'{}');
      if(!visitors[today])visitors[today]=[];
      if(!visitors[today].includes(vid))visitors[today].push(vid);
      localStorage.setItem(ak+'visitors',JSON.stringify(visitors));
      // Track referrer
      if(document.referrer){
        const refs=JSON.parse(localStorage.getItem(ak+'referrers')||'{}');
        const refHost=new URL(document.referrer).hostname;
        refs[refHost]=(refs[refHost]||0)+1;
        localStorage.setItem(ak+'referrers',JSON.stringify(refs));
      }
      // Track device
      const devs=JSON.parse(localStorage.getItem(ak+'devices')||'{}');
      const ua=navigator.userAgent;
      const dev=/Mobile|Android|iPhone/i.test(ua)?'mobile':/Tablet|iPad/i.test(ua)?'tablet':'desktop';
      devs[dev]=(devs[dev]||0)+1;
      localStorage.setItem(ak+'devices',JSON.stringify(devs));
      // Track time on page
      const startTime=Date.now();
      window.addEventListener('beforeunload',()=>{
        const duration=Math.round((Date.now()-startTime)/1000);
        const times=JSON.parse(localStorage.getItem(ak+'times')||'{}');
        if(!times[pg])times[pg]={total:0,count:0};
        times[pg].total+=duration;times[pg].count+=1;
        localStorage.setItem(ak+'times',JSON.stringify(times));
      });
      // Track location via timezone
      const tz=Intl.DateTimeFormat().resolvedOptions().timeZone||'Unknown';
      const locs=JSON.parse(localStorage.getItem(ak+'locations')||'{}');
      locs[tz]=(locs[tz]||0)+1;
      localStorage.setItem(ak+'locations',JSON.stringify(locs));
    }catch(e){}
  })();
  
  const SP='gfs_edit_';
  let user=null,editActive=false,changes=new Map(),originalContent=new Map(),curSelectedEl=null;

  // === OVERRIDES (run on every page load) ===
  function applyHiddenPages(){try{const h=JSON.parse(localStorage.getItem(SP+'hiddenPages')||'[]');if(!h.length)return;document.querySelectorAll('.nav-links>li').forEach(li=>{const a=li.querySelector('a');if(!a)return;if(h.includes(a.getAttribute('href'))){li.style.display='none';li.setAttribute('data-page-hidden','true')}});document.querySelectorAll('.dropdown li').forEach(li=>{const a=li.querySelector('a');if(!a)return;if(h.includes(a.getAttribute('href')))li.style.display='none'});document.querySelectorAll('.site-footer a').forEach(a=>{if(h.includes(a.getAttribute('href'))){const li=a.closest('li');if(li)li.style.display='none'}});}catch(e){}}

  function applyLocalOverrides(){try{const pk=getPageKey(),saved=JSON.parse(localStorage.getItem(SP+'content_'+pk)||'{}');const logoData=JSON.parse(localStorage.getItem(SP+'logo')||'null');function applyLogo(){if(!logoData)return;if(logoData.type==='image'){document.querySelectorAll('.logo,.footer-logo').forEach(container=>{const icon=container.querySelector('.logo-icon');const text=container.querySelector('.logo-text');if(icon){icon.style.display='none'}if(text){text.style.display='none'}let img=container.querySelector('.logo-custom-img');if(!img){img=document.createElement('img');img.className='logo-custom-img';img.style.cssText='max-height:'+(logoData.height||50)+'px;object-fit:contain;';container.prepend(img)}img.src=logoData.src;img.alt=logoData.alt||'Logo'})}else{document.querySelectorAll('.logo-icon').forEach(el=>{if(logoData.icon)el.textContent=logoData.icon});document.querySelectorAll('.company-name').forEach(el=>{if(logoData.name)el.textContent=logoData.name});document.querySelectorAll('.company-tagline').forEach(el=>{if(logoData.tagline)el.textContent=logoData.tagline});document.querySelectorAll('.footer-logo>span').forEach(el=>{if(logoData.name)el.textContent=logoData.name+(logoData.tagline?' '+logoData.tagline:'')})}}if(!Object.keys(saved).length&&!logoData)return;function apply(){const tEls=getEditableTextElements(),imgs=getEditableImages();Object.entries(saved).forEach(([k,v])=>{try{if(k.startsWith('img:')){const i=parseInt(k.split(':')[1]);if(imgs[i])imgs[i].src=v}else if(k.startsWith('imgw:')){const i=parseInt(k.split(':')[1]);if(imgs[i])imgs[i].style.width=v}else if(k.startsWith('imgh:')){const i=parseInt(k.split(':')[1]);if(imgs[i])imgs[i].style.height=v}else if(k.startsWith('alt:')){const i=parseInt(k.split(':')[1]);if(imgs[i]){imgs[i].alt=v;imgs[i].title=v}}else if(k.startsWith('cap:')){const i=parseInt(k.split(':')[1]);if(imgs[i]&&v){const fig=imgs[i].closest('figure');const fc=fig?fig.querySelector('figcaption'):null;const nc=imgs[i].nextElementSibling;const ec=fc||(nc&&(nc.classList.contains('caption')||nc.classList.contains('image-caption'))?nc:null);if(ec)ec.textContent=v;else{const cap=document.createElement('div');cap.className='image-caption';cap.textContent=v;cap.style.cssText='font-size:13px;color:#6b7280;text-align:center;padding:6px 0;';imgs[i].insertAdjacentElement('afterend',cap)}}}else if(k.startsWith('bg:')){const i=parseInt(k.split(':')[1]);const bgs=getEditableBackgrounds();if(bgs[i])bgs[i].style.backgroundImage='url('+v+')'}else if(k.startsWith('style:')){const p=k.split(':');const i=parseInt(p[1]);const prop=p[2];if(tEls[i])tEls[i].style[prop]=v}else{const i=parseInt(k);if(tEls[i]){if(tEls[i].children.length>0)tEls[i].innerHTML=v;else tEls[i].textContent=v}}}catch(e){}});applyLogo()}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',apply);else apply()}catch(e){}}

  function applyColorOverrides(){try{const c=JSON.parse(localStorage.getItem(SP+'colors')||'{}');Object.entries(c).forEach(([v,val])=>document.documentElement.style.setProperty(v,val))}catch(e){}}

  const init=()=>{loadRemoteEdits().then(()=>{applyHiddenPages();applyLocalOverrides();applyColorOverrides()})};

  // === REMOTE EDITS LOADER ===
  async function loadRemoteEdits(){
    try{
      const res=await fetch('/site-edits.json?_='+Date.now());
      if(!res.ok)return;
      const data=await res.json();
      // Populate localStorage with remote data (remote is source of truth for visitors)
      Object.entries(data).forEach(([k,v])=>{
        if(k.startsWith('gfs_edit_')&&!k.startsWith('_')){
          // Only set if localStorage doesn't already have it, OR if not currently in edit mode
          if(!localStorage.getItem(k)||!document.body.classList.contains('edit-mode-active')){
            localStorage.setItem(k,v);
          }
        }
      });
    }catch(e){/* /site-edits.json not deployed yet — use localStorage only */}
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();

  // === HELPERS ===
  function getPageKey(){return(window.location.pathname.replace(/^\/|\/$/g,'')||'home').replace(/\//g,'-')}

  function getEditableTextElements(){
    const sel='h1,h2,h3,h4,h5,h6,p,li,td,th,label,blockquote,figcaption,a,button,span.highlight,span.gold,span.company-name,span.company-tagline,.hero-text,.stat-value,.stat-label,.review-text,.review-author,.card-title,.card-text,.benefit-title,.benefit-text,.cta-content h2,.cta-content p,.section-label,.section-title,details summary,details>p,[data-editable],a.cta-btn,.gbb-tier,.gbb-price,.gbb-label,.gbb-features li,.fence-hero-text,.fence-hero-title,.warranty-badge,.warranty-text,.top-bar-item,.footer-about p,.footer-col h4,.site-footer p,.site-footer a,.city-search,.permits-hero p,.permits-hero h1,.detail-disclaimer p,.area-tag,.btn,.gallery-label,.compare-vs,.logo-icon,.testimonial-stars,.testimonial-avatar,.site-header .nav-links a,.site-header .btn,.footer-logo span';
    const els=[];
    document.querySelectorAll(sel).forEach(el=>{
      if(el.closest('#edit-toolbar')||el.closest('.et-modal')||el.closest('.et-popover')||el.closest('script')||el.closest('style'))return;
      if(!el.textContent?.trim()&&!el.querySelector('img'))return;
      if(el.parentElement?.closest('[data-et-editable]'))return;
            if(el.tagName==='A'&&el.closest('.dropdown'))return;
      if(el.tagName==='LI'&&el.querySelector('a'))return;
      els.push(el);
    });
    return els;
  }

  function getEditableImages(){const imgs=[];document.querySelectorAll('img').forEach(img=>{if(img.closest('#edit-toolbar')||img.closest('.et-modal')||img.closest('.et-popover'))return;if(img.width<30||img.height<30)return;imgs.push(img)});return imgs}

