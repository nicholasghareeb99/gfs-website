  // === LOGO EDITOR ===
  function showLogoEditor(){
    const m=document.getElementById('et-logo-modal');m.style.display='flex';
    const saved=JSON.parse(localStorage.getItem(SP+'logo')||'null');
    const textBtn=document.getElementById('et-logo-type-text'),imgBtn=document.getElementById('et-logo-type-image');
    const textFields=document.getElementById('et-logo-text-fields'),imgFields=document.getElementById('et-logo-image-fields');
    function setType(t){
      if(t==='image'){imgBtn.classList.add('et-btn-save');textBtn.classList.remove('et-btn-save');textFields.style.display='none';imgFields.style.display='block'}
      else{textBtn.classList.add('et-btn-save');imgBtn.classList.remove('et-btn-save');textFields.style.display='block';imgFields.style.display='none'}
    }
    textBtn.onclick=()=>setType('text');imgBtn.onclick=()=>setType('image');
    // Populate current values
    const curIcon=document.querySelector('.logo-icon');const curName=document.querySelector('.company-name');const curTag=document.querySelector('.company-tagline');
    document.getElementById('et-logo-icon').value=saved?.icon||curIcon?.textContent||'GF';
    document.getElementById('et-logo-name').value=saved?.name||curName?.textContent||'GHAREEB';
    document.getElementById('et-logo-tagline').value=saved?.tagline||curTag?.textContent||'FENCING';
    document.getElementById('et-logo-image-url').value=saved?.src||'';
    document.getElementById('et-logo-height').value=saved?.height||50;
    document.getElementById('et-logo-height-val').textContent=(saved?.height||50)+'px';
    document.getElementById('et-logo-height').oninput=e=>{document.getElementById('et-logo-height-val').textContent=e.target.value+'px'};
    if(saved?.type==='image'&&saved.src){setType('image');document.getElementById('et-logo-preview').style.display='block';document.getElementById('et-logo-preview-img').src=saved.src}else{setType('text');document.getElementById('et-logo-preview').style.display='none'}
    // Logo image upload
    const lz=document.getElementById('et-logo-upload-zone');const lfi=document.getElementById('et-logo-file-input');
    lz.onclick=()=>lfi.click();
    lfi.onchange=e=>{const f=e.target.files[0];if(!f||!f.type.startsWith('image/'))return;const r=new FileReader();r.onload=ev=>{document.getElementById('et-logo-preview-img').src=ev.target.result;document.getElementById('et-logo-preview').style.display='block'};r.readAsDataURL(f)};
    lz.ondragover=e=>{e.preventDefault();lz.style.borderColor='#3b82f6'};lz.ondragleave=()=>{lz.style.borderColor='#d1d5db'};
    lz.ondrop=e=>{e.preventDefault();lz.style.borderColor='#d1d5db';const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/')){const dt=new DataTransfer();dt.items.add(f);lfi.files=dt.files;const r=new FileReader();r.onload=ev=>{document.getElementById('et-logo-preview-img').src=ev.target.result;document.getElementById('et-logo-preview').style.display='block'};r.readAsDataURL(f)}};
    document.getElementById('et-logo-cancel').onclick=()=>{m.style.display='none'};
    document.getElementById('et-logo-apply').onclick=()=>{
      const isImage=imgFields.style.display!=='none';
      if(isImage){
        let src='';if(lfi.files[0])src=document.getElementById('et-logo-preview-img').src;else src=document.getElementById('et-logo-image-url').value.trim();
        if(!src){showToast('⚠️ Please upload or enter a logo URL');return}
        const height=parseInt(document.getElementById('et-logo-height').value)||50;
        const logoData={type:'image',src,height,alt:'Company Logo'};
        localStorage.setItem(SP+'logo',JSON.stringify(logoData));
        // Apply immediately
        document.querySelectorAll('.logo,.footer-logo').forEach(container=>{
          const icon=container.querySelector('.logo-icon');const text=container.querySelector('.logo-text');
          if(icon)icon.style.display='none';if(text)text.style.display='none';
          let img=container.querySelector('.logo-custom-img');
          if(!img){img=document.createElement('img');img.className='logo-custom-img';container.prepend(img)}
          img.src=src;img.alt='Company Logo';img.style.cssText='max-height:'+height+'px;object-fit:contain;';
        });
      } else {
        const icon=document.getElementById('et-logo-icon').value.trim()||'GF';
        const name=document.getElementById('et-logo-name').value.trim()||'GHAREEB';
        const tagline=document.getElementById('et-logo-tagline').value.trim()||'FENCING';
        const logoData={type:'text',icon,name,tagline};
        localStorage.setItem(SP+'logo',JSON.stringify(logoData));
        // Apply immediately - remove any custom image first
        document.querySelectorAll('.logo,.footer-logo').forEach(container=>{
          const customImg=container.querySelector('.logo-custom-img');if(customImg)customImg.remove();
          const iconEl=container.querySelector('.logo-icon');const textEl=container.querySelector('.logo-text');
          if(iconEl){iconEl.style.display='';iconEl.textContent=icon}
          if(textEl)textEl.style.display='';
        });
        document.querySelectorAll('.company-name').forEach(el=>{el.textContent=name});
        document.querySelectorAll('.company-tagline').forEach(el=>{el.textContent=tagline});
        document.querySelectorAll('.footer-logo>span').forEach(el=>{el.textContent=name+' '+tagline});
      }
      m.style.display='none';showToast('✅ Logo updated!');pushToGitHub();
    };
  }

