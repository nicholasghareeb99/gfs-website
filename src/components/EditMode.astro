  function exportAllData(){
    const data={};
    for(let i=0;i<localStorage.length;i++){
      const k=localStorage.key(i);
      if(k.startsWith('gfs_'))data[k]=localStorage.getItem(k);
    }
    const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);
    a.download='gfs-site-data-'+new Date().toISOString().split('T')[0]+'.json';
    a.click();showToast('\ud83d\udce4 Data exported!');
  }
  // === UTILITY ===
  function rgbToHex(rgb){if(!rgb||rgb==='transparent'||rgb.includes('0, 0, 0, 0'))return'#ffffff';const m=rgb.match(/\d+/g);if(!m||m.length<3)return'#000000';return'#'+m.slice(0,3).map(x=>parseInt(x).toString(16).padStart(2,'0')).join('')}
  function showToast(msg){const ex=document.getElementById('et-toast');if(ex)ex.remove();const t=document.createElement('div');t.id='et-toast';t.textContent=msg;Object.assign(t.style,{position:'fixed',bottom:'20px',left:'50%',transform:'translateX(-50%)',background:'#1a1a2e',color:'#fff',padding:'10px 24px',borderRadius:'8px',fontSize:'14px',zIndex:'9999999',boxShadow:'0 4px 12px rgba(0,0,0,.3)',fontFamily:'-apple-system,sans-serif'});document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .3s';setTimeout(()=>t.remove(),300)},3000)}
})();
</script>
