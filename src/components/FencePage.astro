.gbb-card{background:#fff;padding:0;text-align:left;position:relative;border-right:1px solid #e5e2dc;display:flex;flex-direction:column}
.gbb-card:last-child{border-right:none}
.gbb-badge{display:block;text-align:center;padding:10px 0;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#fff;background:var(--dark,#1e2a3a)}
