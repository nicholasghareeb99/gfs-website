.gbb-summary-item strong{display:block;font-size:.95rem;color:var(--dark,#1e2a3a);margin-bottom:4px}
.gbb-summary-item span{font-size:.85rem;color:#6b7280}
.gbb-availability{text-align:center;font-size:.85rem;color:#6b7280;font-style:italic;margin-top:16px}
.gbb-contact-bar{max-width:1100px;margin:24px auto 0;background:var(--dark,#1e2a3a);border-radius:12px;padding:20px 32px;display:flex;align-items:center;justify-content:space-between;color:#fff}
.gbb-contact-bar p{margin:0;font-size:1.05rem}
.gbb-contact-bar a{color:var(--accent,#c8a951);font-size:1.3rem;font-weight:700;text-decoration:none}
@media(max-width:900px){.gbb-grid{grid-template-columns:1fr!important}.gbb-card{border-right:none;border-bottom:1px solid #e5e2dc}.gbb-card:last-child{border-bottom:none}.gbb-summary-grid{grid-template-columns:1fr;gap:12px}.gbb-contact-bar{flex-direction:column;text-align:center;gap:12px}}
</style>