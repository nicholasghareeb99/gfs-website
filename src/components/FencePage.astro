---
/**
 * FencePage.astro Reusable layout for individual fence-type pages
 * Props: title, description, keywords, heroTitle, heroHighlight, heroText,
 *        benefits[], specs[], faqs[], galleryImages[], relatedTypes[]
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import siteJson from '../content/site.json';
import { getSiteSettings } from '../lib/firestore.js';

const site = await getSiteSettings();

interface Benefit { icon: string; title: string; text: string; }
interface Spec { label: string; value: string; }
interface FAQ { question: string; answer: string; }
interface GalleryImage { src: string; alt: string; label?: string; }
interface RelatedType { name: string; href: string; image: string; }

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  heroTitle: string;
  heroHighlight: string;
  heroText: string;
  heroImage: string;
  benefits: Benefit[];
  specs: Spec[];
  faqs: FAQ[];
  galleryImages: GalleryImage[];
  relatedTypes: RelatedType[];
  ctaText?: string;
}

const {
  title, description, keywords, heroTitle, heroHighlight, heroText, heroImage,
  benefits, specs, faqs, galleryImages, relatedTypes, ctaText
} = Astro.props;
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <!-- Hero -->
  <section class="fence-hero" style={`background-image: url(${heroImage})`}>
    <div class="fence-hero-overlay">
      <div class="container">
        <div class="fence-hero-content">
          <div class="section-label" style="color: #d4af37; border-color: rgba(212,175,55,0.4); background: rgba(212,175,55,0.1);">&#9733; Premium {heroTitle.split(' ')[0]} Beauty</div>
          <h1 class="fence-hero-title">{heroTitle} <span class="highlight">{heroHighlight}</span></h1>
          <p class="fence-hero-text">{heroText}</p>
          <div class="fence-hero-cta">
            <a href="/quote/" class="btn-hero-gold">Get Instant Quote</a>
            <a href={`tel:${site.company.phoneRaw}`} class="btn-hero-outline">Call {site.company.phone}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Key Benefits</div>
        <h2 class="section-title">Why Choose <span class="gold">{heroHighlight}</span>?</h2>
      </div>
      <div class="benefits-grid">
        {benefits.map((b) => (
          <div class="benefit-card">
            <div class="benefit-icon" set:html={b.icon} />
            <h3>{b.title}</h3>
            <p>{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  {galleryImages.length > 0 && (
    <section class="section section-warm">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Our Work</div>
          <h2 class="section-title">Recent <span class="gold">Installations</span></h2>
        </div>
        <div class="fence-gallery">
          {galleryImages.map((img) => (
            <div class="fence-gallery-item">
              <img src={img.src} alt={img.alt} loading="lazy" />
              {img.label && <div class="fence-gallery-label">{img.label}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Slot for page-specific content (comparisons, options, etc.) -->
  <slot />

  <!-- Specs -->
  {specs.length > 0 && (
    <section class="section section-light">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Specifications</div>
          <h2 class="section-title">Material <span class="gold">Details</span></h2>
        </div>
        <div class="specs-grid">
          {specs.map((s) => (
            <div class="spec-item">
              <div class="spec-label">{s.label}</div>
              <div class="spec-value">{s.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs -->
  {faqs.length > 0 && (
    <section class="section section-warm">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Common Questions</div>
          <h2 class="section-title">Frequently <span class="gold">Asked</span></h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Fence Types -->
  {relatedTypes.length > 0 && (
    <section class="section section-light">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Explore More</div>
          <h2 class="section-title">Other Fence <span class="gold">Styles</span></h2>
        </div>
        <div class="related-grid">
          {relatedTypes.map((rt) => (
            <a href={rt.href} class="related-card">
              <img src={rt.image} alt={rt.name} loading="lazy" />
              <div class="related-overlay">
                <h4>{rt.name}</h4>
                <span class="related-link">Learn More &#8594;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>{ctaText || `Ready for Your New ${heroHighlight}?`}</h2>
        <p>Get your free quote in 60 seconds or talk to an expert today.</p>
        <div class="cta-buttons">
          <a href="/quote/" class="btn btn-primary btn-lg">Get Instant Quote</a>
          <a href={`tel:${site.company.phoneRaw}`} class="btn btn-secondary btn-lg">{site.company.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
/* Good / Better / Best - Premium Card Design */
.gbb-section{padding:80px 24px;background:var(--bg-light,#f8f7f4)}
.gbb-grid{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:0!important;max-width:1100px;margin:0 auto;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.gbb-card{background:#fff;padding:0;text-align:left;position:relative;border-right:1px solid #e5e2dc;display:flex!important;flex-direction:column}
.gbb-card:last-child{border-right:none}
.gbb-badge{display:block;text-align:center;padding:14px 0;font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#fff}
.gbb-card:first-child .gbb-badge{background:#8b8b8b}
.gbb-card:nth-child(2) .gbb-badge{background:var(--dark,#1e2a3a)}
.gbb-card:last-child .gbb-badge{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
.gbb-card.best .gbb-badge{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
.gbb-recommended{display:none}
.gbb-card.best .gbb-recommended,.gbb-card:last-child .gbb-recommended{display:block;text-align:center;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--accent,#c8a951);padding:10px 0 0;text-transform:uppercase}
.gbb-card-body{padding:24px 28px 28px;flex:1;display:flex;flex-direction:column}
.gbb-card-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--dark,#1e2a3a);margin:0 0 20px;text-align:center}
.gbb-features{list-style:none;padding:0;margin:0 0 24px;flex:1}
.gbb-features li{font-size:.9rem;padding:8px 0 8px 24px;position:relative;color:#374151;line-height:1.5;border-bottom:1px solid #f5f3ef}
.gbb-features li:last-child{border-bottom:none}
.gbb-features li::before{content:'\2022';position:absolute;left:4px;color:var(--accent,#c8a951);font-weight:700;font-size:1.2em}
.gbb-card.best .gbb-features li::before,.gbb-card:last-child .gbb-features li::before{content:'\2713';color:#16a34a}
.gbb-cta{display:block;text-align:center;padding:14px 24px;margin-top:auto;background:var(--dark,#1e2a3a);color:#fff;font-weight:700;font-size:.9rem;border-radius:8px;text-decoration:none;letter-spacing:.5px;transition:all .3s}
.gbb-cta:hover{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
.gbb-card.best .gbb-cta,.gbb-card:last-child .gbb-cta{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
.gbb-card.best .gbb-cta:hover,.gbb-card:last-child .gbb-cta:hover{background:var(--dark,#1e2a3a);color:#fff}
/* Legacy class support */
.gbb-tier{display:block;text-align:center;padding:14px 0;font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#fff;background:var(--dark,#1e2a3a)}
.gbb-label{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--dark,#1e2a3a);padding:16px 28px 8px;text-align:center}
.gbb-price{display:none}
.gbb-btn{display:block;text-align:center;padding:14px 24px;margin:auto 28px 28px;background:var(--dark,#1e2a3a);color:#fff;font-weight:700;font-size:.9rem;border-radius:8px;text-decoration:none;transition:all .3s}
.gbb-btn:hover{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
.gbb-card.featured .gbb-tier{background:var(--accent,#c8a951);color:var(--dark,#1e2a3a)}
/* Warranty section */
.warranty-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1000px;margin:0 auto}
.warranty-card{background:#fff;border-radius:12px;padding:32px 24px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.warranty-badge{font-size:2.5rem;margin-bottom:12px;display:block}
.warranty-text{font-size:.95rem;color:#374151;line-height:1.6}
@media(max-width:768px){
.gbb-grid{grid-template-columns:1fr!important}
.gbb-card{border-right:none;border-bottom:1px solid #e5e2dc}
.gbb-card:last-child{border-bottom:none}
.warranty-grid{grid-template-columns:1fr}
}

/* Benefits Grid */
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1080px;margin:0 auto}
.benefit-card{background:#fff;border-radius:12px;padding:28px 20px 24px;text-align:center;border:1px solid #e8e8e8;box-shadow:0 1px 4px rgba(0,0,0,.04);transition:transform .3s,box-shadow .3s}
.benefit-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
.benefit-icon{width:28px!important;height:28px!important;margin:0 auto 12px!important;color:var(--color-secondary,#d4af37);opacity:0.85;display:flex!important;align-items:center;justify-content:center}
.benefit-icon svg{width:28px!important;height:28px!important;max-width:28px!important;max-height:28px!important;flex-shrink:0}
.benefit-card h3{margin-bottom:6px;font-size:.95rem;font-weight:700;color:var(--color-primary,#1e3a5f);letter-spacing:-.01em}
.benefit-card p{color:#666;font-size:.84rem;line-height:1.55;margin:0}
/* GBB Cons */
.gbb-cons{padding:0 24px 16px}
.gbb-cons-title{font-size:.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#dc3545;margin-bottom:10px;padding-bottom:8px;border-bottom:2px solid #f0f0f0}
.gbb-cons ul{list-style:none;padding:0;margin:0;text-align:left}
.gbb-cons li{padding:6px 0 6px 22px;font-size:.88rem;color:#444;position:relative}
.gbb-cons li::before{content:'\2717';position:absolute;left:0;color:#dc3545;font-weight:700}
/* GBB Photo */
.gbb-photo{width:100%;height:180px;object-fit:cover}
/* GBB Title Area */
.gbb-title-area{padding:20px 24px 12px;text-align:center}
.gbb-card-subtitle{font-size:.85rem;color:#888;font-weight:500}
/* GBB Summary */
.gbb-summary{max-width:1080px;margin:32px auto 0;text-align:center;padding:32px 24px;background:#fff;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.gbb-summary-title{font-size:.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--color-primary,#1e3a5f);margin-bottom:20px}
.gbb-summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px}
.gbb-summary-item{display:flex;flex-direction:column;gap:4px}
.gbb-summary-item strong{color:var(--color-primary,#1e3a5f);font-size:.95rem}
.gbb-summary-item span{color:#666;font-size:.85rem}
.gbb-availability{font-size:.85rem;color:#888;margin:12px 0 0}
/* Warranty */
.warranty-badge{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--color-primary,#1e3a5f);margin-bottom:8px}
.warranty-badge span{display:block;font-size:.85rem;font-weight:500;color:#666;font-family:var(--font-body);margin-top:4px}
.warranty-list{list-style:none;padding:0;text-align:left}
.warranty-list li{padding:8px 0;font-size:.92rem;color:#444;border-bottom:1px solid #f0f0f0}
.warranty-list li:last-child{border-bottom:none}
@media(max-width:768px){
.benefits-grid{grid-template-columns:1fr}
.gbb-summary-grid{grid-template-columns:1fr}
}


/* Gallery Grid - Professional constrained layout */
.fence-gallery{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:16px!important;max-width:1080px!important;margin:0 auto!important}
.fence-gallery-item{position:relative;border-radius:12px;overflow:hidden!important;aspect-ratio:4/3!important;background:#f0f0f0;max-height:320px!important}
.fence-gallery-item img{width:100%!important;height:100%!important;object-fit:cover!important;display:block!important;transition:transform .4s ease;max-height:320px!important}
.fence-gallery-item:hover img{transform:scale(1.05)}
.fence-gallery-label{position:absolute;bottom:0;left:0;right:0;padding:10px 16px;background:linear-gradient(transparent,rgba(0,0,0,.7));color:#fff;font-size:.85rem;font-weight:600}
@media(max-width:768px){.fence-gallery{grid-template-columns:repeat(2,1fr);gap:10px}}
@media(max-width:480px){.fence-gallery{grid-template-columns:1fr}}

/* Section spacing tighter */
.section{padding:60px 0}
.section-header{margin-bottom:36px}
.section-label{display:inline-block;font-size:.75rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:20px;border:1px solid #e0e0e0;color:#888;margin-bottom:12px}
.section-title{font-size:2rem;font-weight:700;color:var(--color-primary,#1e3a5f);margin:0}
.section-title .gold{color:var(--color-secondary,#d4af37)}

/* Hero polish */
.fence-hero{min-height:420px;background-size:cover;background-position:center;position:relative}
.fence-hero-overlay{background:linear-gradient(135deg,rgba(30,58,95,.88),rgba(15,39,68,.75));min-height:420px;display:flex;align-items:center}
.fence-hero-content{max-width:680px;padding:60px 0}
.fence-hero-title{font-size:2.8rem;font-weight:700;color:#fff;line-height:1.15;margin:0 0 16px}
.fence-hero-title .highlight{color:var(--color-secondary,#d4af37)}
.fence-hero-text{font-size:1.05rem;color:rgba(255,255,255,.85);line-height:1.7;margin:0 0 28px;max-width:580px}
.fence-hero-cta{display:flex;gap:12px;flex-wrap:wrap}
.btn-hero-gold{display:inline-block;padding:14px 32px;background:var(--color-secondary,#d4af37);color:#1e3a5f;font-weight:700;border-radius:8px;text-decoration:none;font-size:.95rem;transition:all .3s}
.btn-hero-gold:hover{background:#c9a230;transform:translateY(-2px)}
.btn-hero-outline{display:inline-block;padding:14px 32px;border:2px solid rgba(255,255,255,.4);color:#fff;font-weight:600;border-radius:8px;text-decoration:none;font-size:.95rem;transition:all .3s}
.btn-hero-outline:hover{border-color:#fff;background:rgba(255,255,255,.1)}

/* Specs grid */
.specs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:800px;margin:0 auto}
.spec-item{background:#fff;border-radius:10px;padding:20px;text-align:center;border:1px solid #eee}
.spec-label{font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:6px}
.spec-value{font-size:1.1rem;font-weight:700;color:var(--color-primary,#1e3a5f)}
@media(max-width:768px){.specs-grid{grid-template-columns:repeat(2,1fr)}}

/* FAQ */
.faq-list{max-width:800px;margin:0 auto}
.faq-item{border:1px solid #eee;border-radius:10px;margin-bottom:10px;overflow:hidden;background:#fff}
.faq-item summary{padding:18px 24px;font-weight:600;font-size:.95rem;cursor:pointer;color:var(--color-primary,#1e3a5f);list-style:none;display:flex;justify-content:space-between;align-items:center}
.faq-item summary::after{content:'+';font-size:1.3rem;font-weight:300;color:#999;transition:transform .2s}
.faq-item[open] summary::after{transform:rotate(45deg)}
.faq-item p{padding:0 24px 18px;color:#555;font-size:.92rem;line-height:1.7;margin:0}

/* Related fence types */
.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:1000px;margin:0 auto}
.related-card{position:relative;border-radius:12px;overflow:hidden;aspect-ratio:3/2;display:block;text-decoration:none}
.related-card img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.related-card:hover img{transform:scale(1.05)}
.related-overlay{position:absolute;bottom:0;left:0;right:0;padding:20px;background:linear-gradient(transparent,rgba(0,0,0,.75));color:#fff}
.related-overlay h4{margin:0 0 4px;font-size:1.1rem}
.related-link{font-size:.8rem;color:var(--color-secondary,#d4af37);font-weight:600}
@media(max-width:768px){.related-grid{grid-template-columns:1fr}}

/* CTA Section */
.cta-section{background:var(--color-primary,#1e3a5f);padding:60px 0}
.cta-content{text-align:center;max-width:600px;margin:0 auto}
.cta-content h2{color:#fff;font-size:2rem;margin:0 0 12px}
.cta-content p{color:rgba(255,255,255,.8);font-size:1rem;margin:0 0 28px}
.cta-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* Warranty improvements */
.warranty-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:800px;margin:0 auto}
.warranty-card{background:#fff;border-radius:12px;padding:28px 24px;text-align:center;border:1px solid #eee}

</style>
