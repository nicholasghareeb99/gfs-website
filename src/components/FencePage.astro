---
/**
 * FencePage.astro ГѓВѓГ‚ВўГѓВ‚Г‚ВЂГѓВ‚Г‚В” Reusable layout for individual fence-type pages
 * Props: title, description, keywords, heroTitle, heroHighlight, heroText,
 *        benefits[], specs[], faqs[], galleryImages[], relatedTypes[]
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import siteJson from '../content/site.json';
import { getSiteSettings } from '../lib/firestore.js';

const site = await getSiteSettings();

interface Benefit { icon: string; title: string; text: string; }
interface Spec { label: string; value: string; }
interface FAQ { question: string; answer: string; }
interface GalleryImage { src: string; alt: string; label?: string; }
interface RelatedType { name: string; href: string; image: string; }

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  heroTitle: string;
  heroHighlight: string;
  heroText: string;
  heroImage: string;
  benefits: Benefit[];
  specs: Spec[];
  faqs: FAQ[];
  galleryImages: GalleryImage[];
  relatedTypes: RelatedType[];
  ctaText?: string;
}

const {
  title, description, keywords, heroTitle, heroHighlight, heroText, heroImage,
  benefits, specs, faqs, galleryImages, relatedTypes, ctaText
} = Astro.props;
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <!-- Hero -->
  <section class="fence-hero" style={`background-image: url(${heroImage})`}>
    <div class="fence-hero-overlay">
      <div class="container">
        <div class="fence-hero-content">
          <div class="section-label" style="color: #d4af37; border-color: rgba(212,175,55,0.4); background: rgba(212,175,55,0.1);">ГѓВѓГ‚В°ГѓВ‚Г‚ВџГѓВ‚Г‚ВЏГѓВ‚Г‚В  {heroTitle.split(' ')[0]} Beauty</div>
          <h1 class="fence-hero-title">{heroTitle} <span class="highlight">{heroHighlight}</span></h1>
          <p class="fence-hero-text">{heroText}</p>
          <div class="fence-hero-cta">
            <a href="/quote/" class="btn-hero-gold">Get Instant Quote</a>
            <a href={`tel:${site.company.phoneRaw}`} class="btn-hero-outline">Call {site.company.phone}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Key Benefits</div>
        <h2 class="section-title">Why Choose <span class="gold">{heroHighlight}</span>?</h2>
      </div>
      <div class="benefits-grid">
        {benefits.map((b) => (
          <div class="benefit-card">
            <div class="benefit-icon" set:html={b.icon} />
            <h3>{b.title}</h3>
            <p>{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  {galleryImages.length > 0 && (
    <section class="section section-warm">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Our Work</div>
          <h2 class="section-title">Recent <span class="gold">Installations</span></h2>
        </div>
        <div class="fence-gallery">
          {galleryImages.map((img) => (
            <div class="fence-gallery-item">
              <img src={img.src} alt={img.alt} loading="lazy" />
              {img.label && <div class="fence-gallery-label">{img.label}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Slot for page-specific content (comparisons, options, etc.) -->
  <slot />

  <!-- Specs -->
  {specs.length > 0 && (
    <section class="section section-light">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Specifications</div>
          <h2 class="section-title">Material <span class="gold">Details</span></h2>
        </div>
        <div class="specs-grid">
          {specs.map((s) => (
            <div class="spec-item">
              <div class="spec-label">{s.label}</div>
              <div class="spec-value">{s.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs -->
  {faqs.length > 0 && (
    <section class="section section-warm">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Common Questions</div>
          <h2 class="section-title">Frequently <span class="gold">Asked</span></h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Fence Types -->
  {relatedTypes.length > 0 && (
    <section class="section section-light">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Explore More</div>
          <h2 class="section-title">Other Fence <span class="gold">Styles</span></h2>
        </div>
        <div class="related-grid">
          {relatedTypes.map((rt) => (
            <a href={rt.href} class="related-card">
              <img src={rt.image} alt={rt.name} loading="lazy" />
              <div class="related-overlay">
                <h4>{rt.name}</h4>
                <span class="related-link">Learn More ГѓВѓГ‚ВўГѓВ‚Г‚В†ГѓВ‚Г‚В’</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>{ctaText || `Ready for Your New ${heroHighlight}?`}</h2>
        <p>Get your free quote in 60 seconds or talk to an expert today.</p>
        <div class="cta-buttons">
          <a href="/quote/" class="btn btn-primary btn-lg">Get Instant Quote</a>
          <a href={`tel:${site.company.phoneRaw}`} class="btn btn-secondary btn-lg">{site.company.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
/* GBB Good/Better/Best - Premium Brochure Style */
.gbb-section{padding:80px 24px;background:#f8f7f4}
.gbb-grid{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:0!important;max-width:1100px;margin:0 auto;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.1)}
.gbb-card{background:#fff;padding:0;text-align:left;position:relative;border-right:1px solid #e5e2dc;display:flex!important;flex-direction:column}
.gbb-card:last-child{border-right:none}
.gbb-card:hover{transform:translateY(-2px);box-shadow:0 12px 36px rgba(0,0,0,.12);z-index:2}
.gbb-badge{display:block;text-align:center;padding:14px 0;font-size:13px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:#fff}
.gbb-card:nth-child(1) .gbb-badge{background:#8a8a8a}
.gbb-card:nth-child(2) .gbb-badge{background:#1b2d4f}
.gbb-card:nth-child(3) .gbb-badge{background:linear-gradient(135deg,#c9a84c,#dbb960);color:#1b2d4f}
.gbb-card.featured .gbb-badge{background:#1b2d4f}
.gbb-card-body{padding:28px 24px;flex:1;display:flex;flex-direction:column}
.gbb-tier{display:none}
.gbb-price{display:none}
.gbb-recommended{display:none}
.gbb-label{font-size:1.25rem;font-weight:700;color:#1b2d4f;margin-bottom:20px;text-align:center}
.gbb-features{list-style:none;padding:0;margin:0 0 24px;flex:1}
.gbb-features li{padding:10px 0;border-bottom:1px solid #f0ede8;font-size:.95rem;color:#444;display:flex;align-items:center;gap:10px}
.gbb-features li:last-child{border-bottom:none}
.gbb-features li::before{content:"вњ“";color:#2d8a4e;font-weight:700;font-size:1rem;flex-shrink:0}
.gbb-btn{display:block;text-align:center;padding:14px 24px;border-radius:8px;font-weight:700;font-size:.95rem;text-decoration:none;letter-spacing:.5px;transition:all .3s;margin-top:auto}
.gbb-card:nth-child(1) .gbb-btn{background:#f0ede8;color:#1b2d4f}
.gbb-card:nth-child(2) .gbb-btn{background:#1b2d4f;color:#fff}
.gbb-card:nth-child(3) .gbb-btn{background:linear-gradient(135deg,#c9a84c,#dbb960);color:#1b2d4f}
.gbb-card.featured .gbb-btn{background:#1b2d4f;color:#fff}
.gbb-btn:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.15)}
/* New-style classes (cedar) */
.gbb-title-area{text-align:center;padding:28px 24px 16px}
.gbb-card-title{font-size:1.3rem;font-weight:700;color:#1b2d4f}
.gbb-card-subtitle{font-size:.85rem;color:#888;font-weight:500;margin-top:4px}
.gbb-specs{padding:0 24px 16px;flex:1}
.gbb-specs-title{font-size:.75rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent,#c9a84c);margin-bottom:12px}
.gbb-spec-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f0ede8;font-size:.9rem}
.gbb-spec-row:last-child{border-bottom:none}
.gbb-spec-label{color:#777;font-weight:500}
.gbb-spec-value{color:#1b2d4f;font-weight:600;text-align:right}
.gbb-pros{padding:0 24px 16px}
.gbb-pros-title{font-size:.75rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#2d8a4e;margin-bottom:10px}
.gbb-pros ul{list-style:none;padding:0;margin:0}
.gbb-pros li{padding:6px 0;font-size:.88rem;color:#444;display:flex;align-items:center;gap:8px}
.gbb-pros li::before{content:"вњ“";color:#2d8a4e;font-weight:700;flex-shrink:0}
.gbb-cta{padding:16px 24px 28px}
.gbb-cta a{display:block;text-align:center;padding:14px;border-radius:8px;font-weight:700;font-size:.95rem;text-decoration:none;transition:all .3s}
/* Warranty section */
.warranty-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;max-width:800px;margin:0 auto}
.warranty-card{background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.warranty-badge{font-size:2rem;font-weight:800;color:#1b2d4f;margin-bottom:4px}
.warranty-text{color:#555;line-height:1.6}
@media(max-width:900px){.gbb-grid{grid-template-columns:1fr!important}.gbb-card{border-right:none;border-bottom:1px solid #e5e2dc}.gbb-card:last-child{border-bottom:none}}
@media(max-width:768px){.warranty-grid{grid-template-columns:1fr}}
</style>
